def _needs_resize(img_w, img_h, max_w, max_h, mode):
    target_w = max_w or img_w
    target_h = max_h or img_h
    if mode == "shrink":
        return img_w > target_w or img_h > target_h
    elif mode == "grow":
        return img_w < target_w or img_h < target_h
    else:  # stretch
        return img_w != target_w or img_h != target_h


async def resize_to_max_dim(
    source, dest, width, height, mode, kernel=None, scale=None
):
    if kernel is not None:
        if scale is None:
            img_w, img_h = await get_image_dimensions(source)
            scale = width / img_w
        args = [
            "vips",
            "resize",
            source,
            dest,
            str(scale),
            f"--kernel={kernel}",
        ]
    else:
        args = ["vips", "thumbnail", source, dest, str(width)]
        if height is not None:
            args.append(f"--height={height}")
        vips_size = {"shrink": "down", "grow": "up", "stretch": "force"}[mode]
        args.append(f"--size={vips_size}")
    proc = await asyncio.create_subprocess_exec(*args)
    await proc.wait()
    if proc.returncode != 0:
        raise ProcessError(proc)


