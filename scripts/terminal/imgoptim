async def convert_svg_to_png_chromium(source, dest, max_w, max_h, scale=None):
    chromium = shutil.which("chromium") or shutil.which("google-chrome-stable")
    source_url = source.absolute().as_uri()

    # Probe natural dimensions: load SVG as <img>, read naturalWidth/Height
    # via onload into <title>, extract with --dump-dom.
    probe_html = (
        "<!DOCTYPE html><html><head><title>pending</title></head><body>"
        f'<img src="{source_url}" onload="document.title='
        "this.naturalWidth+','+this.naturalHeight\">"
        "</body></html>"
    )

    with TempPath(
        dir=dest.parent, prefix=".imgconvert_svg_", suffix=".html"
    ) as probe_path:
        probe_path.write_text(probe_html)
        proc = await asyncio.create_subprocess_exec(
            chromium,
            "--headless=new",
            "--disable-gpu",
            "--dump-dom",
            "--virtual-time-budget=5000",
            probe_path.absolute().as_uri(),
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.DEVNULL,
        )
        stdout, _ = await proc.communicate()
        if proc.returncode != 0:
            raise ProcessError(proc)

    dom = stdout.decode()
    title_start = dom.find("<title>") + 7
    title_end = dom.find("</title>")
    parts = dom[title_start:title_end].split(",")
    if len(parts) != 2 or parts[0] == "pending":
        raise RuntimeError("failed to probe SVG dimensions via chromium")
    nat_w, nat_h = int(parts[0]), int(parts[1])

    if scale is not None:
        target_w = round(nat_w * scale)
        target_h = round(nat_h * scale)
    elif max_w and max_h:
        target_w, target_h = max_w, max_h
    elif max_w:
        target_w = max_w
        target_h = round(nat_h * max_w / nat_w)
    elif max_h:
        target_h = max_h
        target_w = round(nat_w * max_h / nat_h)
    else:
        target_w, target_h = nat_w, nat_h

    # Render: SVG as <img> with 1px magenta border to find content bounds.
    # 2x window to capture any content overflowing the viewBox.
    render_html = (
        "<!DOCTYPE html><html><head>"
        "<style>*{margin:0;padding:0}html,body{overflow:hidden}"
        "img{display:block;border:1px solid #ff00ff}</style></head>"
        f'<body><img src="{source_url}" '
        f'width="{target_w}" height="{target_h}">'
        "</body></html>"
    )

    with (
        TempPath(
            dir=dest.parent, prefix=".imgconvert_svg_", suffix=".html"
        ) as render_path,
        TempPath(
            dir=dest.parent, prefix=".imgconvert_svg_", suffix=".png"
        ) as screenshot,
    ):
        render_path.write_text(render_html)
        proc = await asyncio.create_subprocess_exec(
            chromium,
            "--headless=new",
            "--disable-gpu",
            f"--screenshot={str(screenshot)}",
            f"--window-size={target_w * 2},{target_h * 2}",
            "--default-background-color=00000000",
            render_path.absolute().as_uri(),
            stderr=asyncio.subprocess.DEVNULL,
        )
        await proc.wait()
        if proc.returncode != 0:
            raise ProcessError(proc)

        # Find magenta border, crop to content inside it.
        proc = await asyncio.create_subprocess_exec(
            "magick",
            "identify",
            "-format",
            "%@",
            str(screenshot),
            stdout=asyncio.subprocess.PIPE,
        )
        stdout, _ = await proc.communicate()
        if proc.returncode != 0:
            raise ProcessError(proc)
        geom = stdout.decode().strip()
        wh, xy = geom.split("+", 1)
        box_w, box_h = (int(v) for v in wh.split("x"))
        box_x, box_y = (int(v) for v in xy.split("+"))

        # Content is 1px inside the border on each side.
        proc = await asyncio.create_subprocess_exec(
            "vips",
            "crop",
            str(screenshot),
            str(dest),
            str(box_x + 1),
            str(box_y + 1),
            str(box_w - 2),
            str(box_h - 2),
        )
        await proc.wait()
        if proc.returncode != 0:
            raise ProcessError(proc)


