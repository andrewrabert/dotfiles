#!/usr/bin/env python3
"""MCP stdio server: pure file ops over a nested tree of .md notes."""

import base64
import json
import os
import pathlib
import subprocess
import sys
import tempfile


class UserError(Exception):
    pass


def json_dumps(data):
    return json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True)


def atomic_write(path, text):
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(
        "w", dir=path.parent, delete=False, encoding="utf-8"
    ) as handle:
        temp_path = pathlib.Path(handle.name)
        try:
            handle.write(text)
            handle.flush()
            temp_path.replace(path)
        finally:
            try:
                temp_path.unlink()
            except FileNotFoundError:
                pass


def slice_lines(text, offset, limit):
    if offset is None and limit is None:
        return text
    lines = text.splitlines()
    start = (offset - 1) if offset else 0
    end = (start + limit) if limit else None
    return "\n".join(lines[start:end])


class McpStdioServer:
    """Reusable JSON-RPC-over-stdio MCP server. Subclass, implement register() to
    declare tools via register_tool(), and set TOOL_ERROR to the exception handlers
    raise for user-facing failures. All MCP protocol — framing, lifecycle, response
    envelope, tool-descriptor shape — lives here; subclasses hold only app logic."""

    PROTOCOL_VERSION = "2025-06-18"
    TOOL_ERROR = Exception  # handlers raise this for a user-facing tool error
    INSTRUCTIONS = (
        None  # optional server-level guidance returned on initialize
    )

    def __init__(self, name, version="1"):
        self.server_info = {"name": name, "version": version}
        self._tools = {}
        self.register()

    def register(self):
        """Override: declare tools by calling register_tool() once per tool."""
        raise NotImplementedError

    def register_tool(self, name, description, input_schema, handler):
        """Register one MCP tool. handler(arguments) -> str. MCP envelope shape lives here."""
        self._tools[name] = {
            "descriptor": {
                "name": name,
                "description": description,
                "inputSchema": input_schema,
            },
            "handler": handler,
        }

    @staticmethod
    def send(message):
        sys.stdout.write(f"{json.dumps(message)}\n")
        sys.stdout.flush()

    def dispatch(self, name, arguments):
        """Return the text result for a tools/call; raise TOOL_ERROR on failure."""
        tool = self._tools.get(name)
        if tool is None:
            raise self.TOOL_ERROR(f"unknown tool: {name}")
        return tool["handler"](arguments or {})

    def handle(self, message):
        method = message.get("method")
        rid = message.get("id")
        if method is None or rid is None:  # response or notification: no reply
            return

        response = {
            "jsonrpc": "2.0",
            "id": rid,
        }

        match method:
            case "initialize":
                params = message.get("params") or {}
                response["result"] = {
                    "protocolVersion": params.get(
                        "protocolVersion", self.PROTOCOL_VERSION
                    ),
                    "capabilities": {"tools": {}},
                    "serverInfo": self.server_info,
                }
                if self.INSTRUCTIONS:
                    response["result"]["instructions"] = self.INSTRUCTIONS
            case "tools/list":
                response["result"] = {
                    "tools": [t["descriptor"] for t in self._tools.values()]
                }
            case "tools/call":
                params = message.get("params") or {}
                try:
                    text = self.dispatch(
                        params.get("name"), params.get("arguments")
                    )
                    response["result"] = {
                        "content": [{"type": "text", "text": text}],
                        "isError": False,
                    }
                except self.TOOL_ERROR as error:
                    response["result"] = {
                        "content": [
                            {"type": "text", "text": f"error: {error}"}
                        ],
                        "isError": True,
                    }
                except (
                    Exception
                ) as error:  # a tool bug must not kill the server
                    response["result"] = {
                        "content": [
                            {
                                "type": "text",
                                "text": f"error: internal: {error}",
                            }
                        ],
                        "isError": True,
                    }
            case "ping":
                response["result"] = {}
            case _:
                response["error"] = {
                    "code": -32601,
                    "message": f"method not found: {method}",
                }
        self.send(response)

    def serve(self):
        for line in sys.stdin:
            line = line.strip()
            if not line:
                continue
            try:
                message = json.loads(line)
            except json.JSONDecodeError:
                continue
            self.handle(message)


def resolve_root():
    root = os.environ.get("NOTES_DIR")
    if not root:
        raise UserError("no notes dir set (set NOTES_DIR)")
    return pathlib.Path(root).expanduser()


def ripgrep(root, pattern, base, context):
    """Run `rg --json` and parse its JSON Lines into
    {abs_path: {line_number: line_text}}. Match and context lines are merged."""
    cmd = [
        "rg",
        "--json",
        "--no-ignore",
        "--hidden",
        "-i",
        "--regexp",
        pattern,
    ]
    if context:
        cmd += ["--context", str(context)]
    cmd += [
        "--",
        str(base),
    ]  # always: with no path & piped stdin rg reads stdin
    try:
        proc = subprocess.run(
            cmd, cwd=str(root), capture_output=True, text=True
        )
    except FileNotFoundError:
        raise UserError("rg not found")
    if proc.returncode == 1:  # no matches
        return {}
    if proc.returncode != 0:
        raise UserError(f"rg: {proc.stderr.strip() or proc.returncode}")
    hits = {}
    for line in proc.stdout.splitlines():
        if not line:
            continue
        event = json.loads(line)
        if event.get("type") not in ("match", "context"):
            continue
        data = event["data"]
        path = (root / data["path"]["text"]).resolve()
        lines = data["lines"]
        text = lines.get("text")
        if text is None:  # non-utf8 line: rg base64-encodes it
            text = base64.b64decode(lines["bytes"]).decode("utf-8", "replace")
        hits.setdefault(path, {})[data["line_number"]] = text.rstrip("\n")
    return hits


def walk_tree(base):
    """Every file and subdir under base as absolute paths; [base] if base is a
    file."""
    if base.is_file():
        return [base]
    found = []
    for dirpath, dirnames, filenames in os.walk(base):
        parent = pathlib.Path(dirpath)
        for name in dirnames + filenames:
            found.append(parent / name)
    return found


class Notes:
    TRASH = ".trash"

    def __init__(self, path):
        self.root_path = path

    @property
    def trash_path(self):
        return self.root_path / self.TRASH

    def get_path(self, path=None):
        if path is None:
            return self.root_path
        resolved = (self.root_path / path).resolve()
        root = self.root_path.resolve()
        if resolved != root and root not in resolved.parents:
            raise UserError(f"path escapes notes root: '{path}'")
        return resolved

    def _in_trash(self, path):
        trash = self.trash_path.resolve()
        return trash in (path, *path.parents)

    def _filter_paths(self, paths, trash=False):
        return [p for p in paths if self._in_trash(p) == trash]

    def _scoped_base(self, path, trash):
        base = self.trash_path if trash else self.root_path
        return self.get_path(base / path if path else base)

    def search(self, pattern, path=None, lines=1, trash=False):
        if not pattern:
            raise UserError("pattern required")
        base = self._scoped_base(path, trash)
        hits = ripgrep(
            self.root_path, pattern, base, 0 if lines == 0 else lines
        )
        keep = set(self._filter_paths(hits, trash=trash))
        return {p: v for p, v in hits.items() if p in keep}

    def list(self, path=None, trash=False):
        base = self._scoped_base(path, trash)
        return self._filter_paths(walk_tree(base), trash=trash)

    def _resolve_file(self, rel):
        if not rel:
            raise UserError("path required")
        if rel.endswith("/"):
            raise UserError(f"path must be a file: '{rel}'")
        return self.get_path(rel)

    def read(self, rel):
        path = self._resolve_file(rel)
        if not path.is_file():
            raise UserError(f"no note at '{rel}'")
        try:
            return path.read_text(encoding="utf-8")
        except UnicodeDecodeError:
            raise UserError(f"note is not valid utf-8: '{rel}'")

    def write(self, rel, content):
        atomic_write(self._resolve_file(rel), content)

    def move(self, rel, dest, overwrite):
        src = self._resolve_file(rel)
        if not src.is_file():
            raise UserError(f"no note at '{rel}'")
        target = self._resolve_file(dest)
        if target.exists() and not overwrite:
            raise UserError(f"destination exists: '{dest}' (pass overwrite)")
        target.parent.mkdir(parents=True, exist_ok=True)
        src.replace(target)

    def delete(self, rel):
        path = self._resolve_file(rel)
        if not path.is_file():
            raise UserError(f"no note at '{rel}'")
        if self._in_trash(path):
            raise UserError(f"already in {self.TRASH}: '{rel}'")
        trash = self._unique(self.trash_path / rel)
        trash.parent.mkdir(parents=True, exist_ok=True)
        path.replace(trash)
        return str(trash.relative_to(self.root_path))

    @staticmethod
    def _unique(path):
        candidate = path
        count = 1
        while candidate.exists():
            candidate = path.with_name(f"{path.stem} {count}{path.suffix}")
            count += 1
        return candidate


class NotesMcp(McpStdioServer):
    TOOL_ERROR = UserError
    INSTRUCTIONS = (
        "File-backed notes store over a nested tree of .md files. Use these "
        "tools to search, list, read, write, edit, move, and delete notes by "
        "relative path (e.g. 'proj/ideas.md')."
    )

    def __init__(self, notes):
        self.notes = notes
        super().__init__(name="notes", version="1")

    def register(self):
        self.register_tool(
            "SearchNotes",
            "Search note contents with ripgrep (--json, parsed). 'pattern': "
            "regex (required), matched per line. 'dir': relative directory to "
            "scope to (default: whole tree) — a literal path, NOT a glob. "
            "'lines' (default 1): context lines, or 0 for matching paths "
            "only. 'trash': search only inside .trash/ (excluded by default). "
            "Returns 'path:lineno:text' lines, '--' between files; with "
            "lines=0, matching paths one per line.",
            {
                "type": "object",
                "properties": {
                    "pattern": {
                        "type": "string",
                        "description": "ripgrep regex, matched per line",
                    },
                    "dir": {
                        "type": "string",
                        "description": "relative directory to scope to",
                    },
                    "lines": {
                        "type": "integer",
                        "default": 1,
                        "description": "context lines, or 0 for paths only",
                    },
                    "trash": {
                        "type": "boolean",
                        "default": False,
                        "description": "search only inside .trash/",
                    },
                },
                "required": ["pattern"],
            },
            self._search,
        )
        self.register_tool(
            "List",
            "Recursively list all files and folders under a directory "
            "(default: notes root). 'path': relative dir prefix. 'trash': when "
            "true, list only inside .trash/ (excluded by default). Directories "
            "end with '/'.",
            {
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "relative dir prefix",
                    },
                    "trash": {
                        "type": "boolean",
                        "default": False,
                        "description": "list only inside .trash/",
                    },
                },
            },
            self._list,
        )
        self.register_tool(
            "ReadNote",
            "Read a note's text by relative path. Use offset/limit to page.",
            {
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "relative path, e.g. 'proj/ideas.md'",
                    },
                    "offset": {
                        "type": "integer",
                        "description": "1-based start line",
                    },
                    "limit": {"type": "integer", "description": "max lines"},
                },
                "required": ["path"],
            },
            self._read,
        )
        self.register_tool(
            "WriteNote",
            "Write a note, overwriting it. Creates parent directories.",
            {
                "type": "object",
                "properties": {
                    "path": {"type": "string", "description": "relative path"},
                    "content": {"type": "string", "description": "note text"},
                },
                "required": ["path", "content"],
            },
            self._write,
        )
        self.register_tool(
            "EditNote",
            "Revise a note in place via string-replace.",
            {
                "type": "object",
                "properties": {
                    "path": {"type": "string", "description": "relative path"},
                    "old_string": {
                        "type": "string",
                        "description": "exact string to replace",
                    },
                    "new_string": {
                        "type": "string",
                        "description": "replacement",
                    },
                    "replace_all": {
                        "type": "boolean",
                        "default": False,
                        "description": "replace every occurrence",
                    },
                },
                "required": ["path", "old_string", "new_string"],
            },
            self._edit,
        )
        self.register_tool(
            "MoveNote",
            "Move or rename a note within the tree. Creates parent dirs.",
            {
                "type": "object",
                "properties": {
                    "path": {"type": "string", "description": "source path"},
                    "dest": {
                        "type": "string",
                        "description": "destination path",
                    },
                    "overwrite": {
                        "type": "boolean",
                        "default": False,
                        "description": "allow overwriting dest",
                    },
                },
                "required": ["path", "dest"],
            },
            self._move,
        )
        self.register_tool(
            "DeleteNote",
            "Move a note to .trash/ (recoverable) by relative path.",
            {
                "type": "object",
                "properties": {
                    "path": {"type": "string", "description": "relative path"}
                },
                "required": ["path"],
            },
            self._delete,
        )

    def _rel(self, path):
        return str(path.relative_to(self.notes.root_path.resolve()))

    def _search(self, arguments):
        lines = arguments.get("lines", 1)
        hits = self.notes.search(
            arguments.get("pattern"),
            arguments.get("dir"),
            lines,
            arguments.get("trash", False),
        )
        if lines == 0:
            return "\n".join(sorted(self._rel(p) for p in hits))
        blocks = []
        for path in sorted(hits, key=self._rel):
            rel = self._rel(path)
            blocks.append(
                "\n".join(
                    f"{rel}:{num}:{text}"
                    for num, text in sorted(hits[path].items())
                )
            )
        return "\n--\n".join(blocks)

    def _list(self, arguments):
        paths = self.notes.list(
            arguments.get("path"), arguments.get("trash", False)
        )
        return "\n".join(
            sorted(self._rel(p) + ("/" if p.is_dir() else "") for p in paths)
        )

    def _read(self, arguments):
        return slice_lines(
            self.notes.read(arguments.get("path", "")),
            arguments.get("offset"),
            arguments.get("limit"),
        )

    def _write(self, arguments):
        rel = arguments.get("path", "")
        self.notes.write(rel, arguments.get("content", ""))
        return f"wrote {rel}"

    def _edit(self, arguments):
        rel = arguments.get("path", "")
        content = self.notes.read(rel)
        old = arguments.get("old_string", "")
        count = content.count(old)
        if count == 0:
            raise UserError("old string not found")
        if count > 1 and not arguments.get("replace_all"):
            raise UserError(
                f"old string not unique ({count} matches); pass replace_all"
            )
        self.notes.write(
            rel, content.replace(old, arguments.get("new_string", ""))
        )
        return f"edited {rel}"

    def _move(self, arguments):
        rel = arguments.get("path", "")
        dest = arguments.get("dest", "")
        self.notes.move(rel, dest, arguments.get("overwrite", False))
        return f"moved {rel} -> {dest}"

    def _delete(self, arguments):
        rel = arguments.get("path", "")
        trash = self.notes.delete(rel)
        return f"moved {rel} to {trash}"


def main():
    NotesMcp(Notes(resolve_root())).serve()


if __name__ == "__main__":
    try:
        main()
    except UserError as error:
        print(f"error: {error}", file=sys.stderr)
        sys.exit(1)
