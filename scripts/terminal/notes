#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# dependencies = [
#   "pydantic-settings>=2.6",
#   "pyyaml>=6",
# ]
# ///
"""MCP stdio server + mirrored CLI: pure file ops over a tree of .md notes."""

import base64
import datetime
import json
import os
import pathlib
import platform
import subprocess
import sys
import tempfile
import typing

import pydantic
import pydantic_settings
import yaml


class UserError(Exception):
    pass


def json_dumps(data):
    return json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True)


def atomic_write(path, text):
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(
        "w", dir=path.parent, delete=False, encoding="utf-8"
    ) as handle:
        temp_path = pathlib.Path(handle.name)
        try:
            handle.write(text)
            handle.flush()
            temp_path.replace(path)
        finally:
            try:
                temp_path.unlink()
            except FileNotFoundError:
                pass


def slice_lines(text, offset, limit):
    if offset is None and limit is None:
        return text
    lines = text.splitlines()
    start = (offset - 1) if offset else 0
    end = (start + limit) if limit else None
    return "\n".join(lines[start:end])


class McpStdioServer:
    """Reusable JSON-RPC-over-stdio MCP server. Subclass, implement register() to
    declare tools via register_tool(), and set TOOL_ERROR to the exception handlers
    raise for user-facing failures. All MCP protocol — framing, lifecycle, response
    envelope, tool-descriptor shape — lives here; subclasses hold only app logic."""

    PROTOCOL_VERSION = "2025-06-18"
    TOOL_ERROR = Exception  # handlers raise this for a user-facing tool error
    INSTRUCTIONS = (
        None  # optional server-level guidance returned on initialize
    )

    def __init__(self, name, version="1"):
        self.server_info = {"name": name, "version": version}
        self._tools = {}
        self.register()

    def register(self):
        """Override: declare tools by calling register_tool() once per tool."""
        raise NotImplementedError

    def register_tool(self, name, description, input_schema, handler):
        """Register one MCP tool. handler(arguments) -> str. MCP envelope shape lives here."""
        self._tools[name] = {
            "descriptor": {
                "name": name,
                "description": description,
                "inputSchema": input_schema,
            },
            "handler": handler,
        }

    @staticmethod
    def send(message):
        sys.stdout.write(f"{json.dumps(message)}\n")
        sys.stdout.flush()

    def dispatch(self, name, arguments):
        """Return the text result for a tools/call; raise TOOL_ERROR on failure."""
        tool = self._tools.get(name)
        if tool is None:
            raise self.TOOL_ERROR(f"unknown tool: {name}")
        return tool["handler"](arguments or {})

    def handle(self, message):
        method = message.get("method")
        rid = message.get("id")
        if method is None or rid is None:  # response or notification: no reply
            return

        response = {
            "jsonrpc": "2.0",
            "id": rid,
        }

        match method:
            case "initialize":
                params = message.get("params") or {}
                response["result"] = {
                    "protocolVersion": params.get(
                        "protocolVersion", self.PROTOCOL_VERSION
                    ),
                    "capabilities": {"tools": {}},
                    "serverInfo": self.server_info,
                }
                if self.INSTRUCTIONS:
                    response["result"]["instructions"] = self.INSTRUCTIONS
            case "tools/list":
                response["result"] = {
                    "tools": [t["descriptor"] for t in self._tools.values()]
                }
            case "tools/call":
                params = message.get("params") or {}
                try:
                    text = self.dispatch(
                        params.get("name"), params.get("arguments")
                    )
                    response["result"] = {
                        "content": [{"type": "text", "text": text}],
                        "isError": False,
                    }
                except self.TOOL_ERROR as error:
                    response["result"] = {
                        "content": [
                            {"type": "text", "text": f"error: {error}"}
                        ],
                        "isError": True,
                    }
                except (
                    Exception
                ) as error:  # a tool bug must not kill the server
                    response["result"] = {
                        "content": [
                            {
                                "type": "text",
                                "text": f"error: internal: {error}",
                            }
                        ],
                        "isError": True,
                    }
            case "ping":
                response["result"] = {}
            case _:
                response["error"] = {
                    "code": -32601,
                    "message": f"method not found: {method}",
                }
        self.send(response)

    def serve(self):
        for line in sys.stdin:
            line = line.strip()
            if not line:
                continue
            try:
                message = json.loads(line)
            except json.JSONDecodeError:
                continue
            self.handle(message)


def resolve_root():
    root = os.environ.get("NOTES_DIR")
    if not root:
        raise UserError("no notes dir set (set NOTES_DIR)")
    return pathlib.Path(root).expanduser()


def resolve_source(explicit=None):
    """Log source: the explicit -s/--source flag wins, else NOTES_SOURCE env,
    else None (omitted from metadata)."""
    return explicit or os.environ.get("NOTES_SOURCE") or None


def log_metadata(now):
    """System-generated log-entry metadata: creation time (with offset), cwd, host.
    Nothing user-supplied."""
    return {
        "created": now.isoformat(),
        "cwd": os.getcwd(),
        "host": platform.node(),
    }


def ripgrep(root, pattern, base, context):
    """Run `rg --json` and parse its JSON Lines into
    {abs_path: {line_number: line_text}}. Match and context lines are merged."""
    cmd = [
        "rg",
        "--json",
        "--no-ignore",
        "--hidden",
        "-S",
        "--regexp",
        pattern,
    ]
    if context:
        cmd += ["--context", str(context)]
    cmd += [
        "--",
        str(base),
    ]  # always: with no path & piped stdin rg reads stdin
    try:
        proc = subprocess.run(
            cmd, cwd=str(root), capture_output=True, text=True
        )
    except FileNotFoundError:
        raise UserError("rg not found")
    if proc.returncode == 1:  # no matches
        return {}
    if proc.returncode != 0:
        raise UserError(f"rg: {proc.stderr.strip() or proc.returncode}")
    hits = {}
    for line in proc.stdout.splitlines():
        if not line:
            continue
        event = json.loads(line)
        if event.get("type") not in ("match", "context"):
            continue
        data = event["data"]
        path = (root / data["path"]["text"]).resolve()
        lines = data["lines"]
        text = lines.get("text")
        if text is None:  # non-utf8 line: rg base64-encodes it
            text = base64.b64decode(lines["bytes"]).decode("utf-8", "replace")
        hits.setdefault(path, {})[data["line_number"]] = text.rstrip("\n")
    return hits


def match_paths(pattern, rel_paths):
    """Filter rel_paths to those matching pattern, using the same rg flags as
    ripgrep() so path and content matching share smart-case and regex dialect."""
    if not rel_paths:
        return set()
    cmd = ["rg", "--no-ignore", "--hidden", "-S", "--regexp", pattern]
    try:
        proc = subprocess.run(
            cmd, input="\n".join(rel_paths), capture_output=True, text=True
        )
    except FileNotFoundError:
        raise UserError("rg not found")
    if proc.returncode == 1:  # no matches
        return set()
    if proc.returncode != 0:
        raise UserError(f"rg: {proc.stderr.strip() or proc.returncode}")
    return set(proc.stdout.splitlines())


def walk_tree(base):
    """Every file and subdir under base as absolute paths; [base] if base is a
    file."""
    if base.is_file():
        return [base]
    found = []
    for dirpath, dirnames, filenames in os.walk(base):
        parent = pathlib.Path(dirpath)
        for name in dirnames + filenames:
            found.append(parent / name)
    return found


class Notes:
    TRASH = ".trash"
    LOG = "Log"
    META_SUFFIX = ".md.meta"

    def __init__(self, path, source=None):
        self.root_path = path
        self.source = source

    @property
    def trash_path(self):
        return self.root_path / self.TRASH

    @property
    def log_path(self):
        return self.root_path / self.LOG

    def get_path(self, path=None):
        if path is None:
            return self.root_path
        resolved = (self.root_path / path).resolve()
        root = self.root_path.resolve()
        if resolved != root and root not in resolved.parents:
            raise UserError(f"path escapes notes root: '{path}'")
        return resolved

    def _in_trash(self, path):
        trash = self.trash_path.resolve()
        return trash in (path, *path.parents)

    def _filter_paths(self, paths, trash=False):
        return [p for p in paths if self._in_trash(p) == trash]

    def _under_log(self, path):
        log_root = self.log_path.resolve()
        return path == log_root or log_root in path.parents

    def _is_meta(self, path):
        """A log metadata sidecar: '<entry>.md.meta' under Log/ only. A stray
        '*.md.meta' elsewhere in the tree is an ordinary note, not a sidecar."""
        return path.name.endswith(self.META_SUFFIX) and self._under_log(path)

    def _filter_meta(self, paths, meta=False):
        return [p for p in paths if self._is_meta(p) == meta]

    def _is_log(self, path):
        """A log entry or its sidecar: anything under Log/."""
        return self._under_log(path)

    def _guard_log(self, path, rel):
        if self._is_log(path):
            raise UserError(f"log entries are immutable: '{rel}'")

    def _scoped_base(self, path, trash):
        base = self.trash_path if trash else self.root_path
        return self.get_path(base / path if path else base)

    def grep(self, pattern, context=1, trash=False, prefix=None, meta=False):
        if not pattern:
            raise UserError("pattern required")
        base = self._scoped_base(prefix, trash)
        hits = ripgrep(self.root_path, pattern, base, context)
        keep = set(self._filter_paths(hits, trash=trash))
        keep = set(self._filter_meta(keep, meta=meta))
        return {p: v for p, v in hits.items() if p in keep}

    def match_path(self, pattern, trash=False, prefix=None, meta=False):
        if not pattern:
            raise UserError("pattern required")
        base = self._scoped_base(prefix, trash)
        files = [
            p
            for p in self._filter_paths(walk_tree(base), trash=trash)
            if p.is_file()
        ]
        files = self._filter_meta(files, meta=meta)
        by_rel = {rel_to(self, p): p for p in files}
        return {
            by_rel[rel]
            for rel in match_paths(pattern, list(by_rel))
            if rel in by_rel
        }

    def _resolve_file(self, rel):
        if not rel:
            raise UserError("path required")
        if rel.endswith("/"):
            raise UserError(f"path must be a file: '{rel}'")
        return self.get_path(rel)

    def _resolve_movable(self, rel):
        stripped = rel.rstrip("/") if rel else rel
        if not stripped:
            raise UserError("path required")
        return self.get_path(stripped)

    def read(self, rel):
        path = self._resolve_file(rel)
        if not path.is_file():
            raise UserError(f"no note at '{rel}'")
        try:
            return path.read_text(encoding="utf-8")
        except UnicodeDecodeError:
            raise UserError(f"note is not valid utf-8: '{rel}'")

    def write(self, rel, content):
        path = self._resolve_file(rel)
        self._guard_log(path, rel)
        atomic_write(path, content)

    def create_log(self, body):
        now = datetime.datetime.now().astimezone()
        meta = log_metadata(now)
        if (
            self.source
        ):  # server-lifecycle / CLI-invocation constant, omit if unset
            meta["source"] = self.source
        rel_dir = f"{self.LOG}/{now:%Y}/{now:%m}"
        stamp = now.strftime("%Y-%m-%dT%H-%M-%S.%f")
        rel_md, rel_meta = self._unique_log(rel_dir, stamp)
        atomic_write(
            self.get_path(rel_meta),
            yaml.safe_dump(meta, sort_keys=False, allow_unicode=True),
        )
        atomic_write(
            self.get_path(rel_md), body if body.endswith("\n") else body + "\n"
        )
        return rel_md

    def _unique_log(self, rel_dir, stamp):
        count = 0
        while True:
            suffix = "" if count == 0 else f"-{count}"
            rel_md = f"{rel_dir}/{stamp}{suffix}.md"
            rel_meta = rel_md + ".meta"
            if not self.get_path(rel_md).exists() and not (
                self.get_path(rel_meta).exists()
            ):
                return rel_md, rel_meta
            count += 1

    def move(self, rel, dest, overwrite):
        src = self._resolve_movable(rel)
        if not src.exists():
            raise UserError(f"no note or folder at '{rel}'")
        target = self._resolve_movable(dest)
        self._guard_log(src, rel)
        self._guard_log(target, dest)
        if target == src:
            raise UserError("source and destination are the same")
        if src in target.parents:
            raise UserError(f"cannot move a folder into itself: '{rel}'")
        if target.exists() and not overwrite:
            raise UserError(f"destination exists: '{dest}' (pass overwrite)")
        target.parent.mkdir(parents=True, exist_ok=True)
        try:
            src.replace(target)
        except OSError:
            raise UserError(f"cannot overwrite non-empty folder: '{dest}'")

    def delete(self, rel):
        path = self._resolve_file(rel)
        if not path.is_file():
            raise UserError(f"no note at '{rel}'")
        self._guard_log(path, rel)
        if self._in_trash(path):
            raise UserError(f"already in {self.TRASH}: '{rel}'")
        trash = self._unique(self.trash_path / rel)
        trash.parent.mkdir(parents=True, exist_ok=True)
        path.replace(trash)
        return str(trash.relative_to(self.root_path))

    @staticmethod
    def _unique(path):
        candidate = path
        count = 1
        while candidate.exists():
            candidate = path.with_name(f"{path.stem} {count}{path.suffix}")
            count += 1
        return candidate


def rel_to(notes, path):
    return str(path.relative_to(notes.root_path.resolve()))


class SearchNotes(pydantic.BaseModel):
    """Find notes by regex. 'pattern' is a ripgrep regex, smart-case (insensitive unless it contains an uppercase letter; use '(?i)'/'(?-i)' to force); defaults to '.' (matches everything, i.e. lists). 'mode' selects what it matches: 'any' (default) returns paths where the relative path OR the contents match; 'path' matches the relative path only, returning paths; 'content' matches contents only, returning 'path:lineno:text' lines ('--' between files) with 'context' surrounding lines (0 for matching paths only). 'prefix': literal relative subtree to scope to (default: whole tree), NOT a glob. 'trash': search only inside .trash/ (excluded by default). 'meta': search only log metadata sidecars (*.md.meta), excluded by default; use it to query log entries by created/cwd/host/session_id."""

    pattern: pydantic_settings.CliPositionalArg[str] = pydantic.Field(
        ".", description="ripgrep regex (default '.': match everything)"
    )
    mode: typing.Literal["any", "content", "path"] = pydantic.Field(
        "any", description="what to match: path or contents, contents, or path"
    )
    context: int = pydantic.Field(
        1, description="context lines around each match (content mode)"
    )
    prefix: str | None = pydantic.Field(
        None, description="relative subtree to scope to"
    )
    trash: bool = pydantic.Field(
        False, description="search only inside .trash/"
    )
    meta: bool = pydantic.Field(
        False, description="search only log metadata sidecars (*.md.meta)"
    )

    def run(self, notes):
        if self.mode == "content":
            hits = notes.grep(
                self.pattern, self.context, self.trash, self.prefix, self.meta
            )
            if self.context == 0:
                return "\n".join(sorted(rel_to(notes, p) for p in hits))
            blocks = []
            for path in sorted(hits, key=lambda p: rel_to(notes, p)):
                rel = rel_to(notes, path)
                blocks.append(
                    "\n".join(
                        f"{rel}:{num}:{text}"
                        for num, text in sorted(hits[path].items())
                    )
                )
            return "\n--\n".join(blocks)
        paths = notes.match_path(
            self.pattern, self.trash, self.prefix, self.meta
        )
        if self.mode == "any":
            paths = paths | set(
                notes.grep(self.pattern, 0, self.trash, self.prefix, self.meta)
            )
        return "\n".join(sorted(rel_to(notes, p) for p in paths))

    def cli_cmd(self):
        print(self.run(Notes(resolve_root())))


class ReadNote(pydantic.BaseModel):
    """Read a note's text by relative path. Use offset/limit to page."""

    path: pydantic_settings.CliPositionalArg[str] = pydantic.Field(
        description="relative path, e.g. 'proj/ideas.md'"
    )
    offset: int | None = pydantic.Field(None, description="1-based start line")
    limit: int | None = pydantic.Field(None, description="max lines")

    def run(self, notes):
        return slice_lines(notes.read(self.path), self.offset, self.limit)

    def cli_cmd(self):
        print(self.run(Notes(resolve_root())))


class WriteNote(pydantic.BaseModel):
    """Write a note, overwriting it. Creates parent directories. Never use for logging or timestamped entries — those must go through LogNote."""

    path: pydantic_settings.CliPositionalArg[str] = pydantic.Field(
        description="relative path"
    )
    content: pydantic_settings.CliPositionalArg[str] = pydantic.Field(
        description="note text"
    )

    def run(self, notes):
        notes.write(self.path, self.content)
        return f"wrote {self.path}"

    def cli_cmd(self):
        print(self.run(Notes(resolve_root())))


class EditNote(pydantic.BaseModel):
    """Revise a note in place via string-replace."""

    path: pydantic_settings.CliPositionalArg[str] = pydantic.Field(
        description="relative path"
    )
    old_string: pydantic_settings.CliPositionalArg[str] = pydantic.Field(
        description="exact string to replace"
    )
    new_string: pydantic_settings.CliPositionalArg[str] = pydantic.Field(
        description="replacement"
    )
    replace_all: bool = pydantic.Field(
        False, description="replace every occurrence"
    )

    def run(self, notes):
        content = notes.read(self.path)
        count = content.count(self.old_string)
        if count == 0:
            raise UserError("old string not found")
        if count > 1 and not self.replace_all:
            raise UserError(
                f"old string not unique ({count} matches); pass replace_all"
            )
        notes.write(
            self.path, content.replace(self.old_string, self.new_string)
        )
        return f"edited {self.path}"

    def cli_cmd(self):
        print(self.run(Notes(resolve_root())))


class MoveNote(pydantic.BaseModel):
    """Move or rename a note or folder within the tree. A folder moves its whole subtree. Creates missing parent dirs. 'overwrite' replaces an existing file; a non-empty destination folder is refused."""

    path: pydantic_settings.CliPositionalArg[str] = pydantic.Field(
        description="source path (note or folder)"
    )
    dest: pydantic_settings.CliPositionalArg[str] = pydantic.Field(
        description="destination path"
    )
    overwrite: bool = pydantic.Field(
        False,
        description="replace an existing file (non-empty folders refused)",
    )

    def run(self, notes):
        notes.move(self.path, self.dest, self.overwrite)
        return f"moved {self.path} -> {self.dest}"

    def cli_cmd(self):
        print(self.run(Notes(resolve_root())))


class DeleteNote(pydantic.BaseModel):
    """Move a note to .trash/ (recoverable) by relative path."""

    path: pydantic_settings.CliPositionalArg[str] = pydantic.Field(
        description="relative path"
    )

    def run(self, notes):
        trash = notes.delete(self.path)
        return f"moved {self.path} to {trash}"

    def cli_cmd(self):
        print(self.run(Notes(resolve_root())))


class LogNote(pydantic.BaseModel):
    """Append an immutable, timestamped log entry. 'body' is free-form; all metadata (created time with offset, cwd, host) is captured automatically into a YAML sidecar — nothing to fill in. Entries are written under Log/YYYY/MM/ and CANNOT be edited, moved, or deleted through these tools; they are write-once. They still appear in SearchNotes (the sidecar metadata is searchable via SearchNotes' 'meta' flag).

    IMPORTANT: You MUST end 'body' with an attribution trailer as its own final line, formatted EXACTLY as: '-- <who> · <session-id>' — set <who> to a short identifier of what you are (e.g. 'claude-code') and <session-id> to your current session id. The separator is a middle dot ' · '. Always append this trailer to every entry; it is the sole means of attributing the entry. Never omit it or change its format."""

    body: pydantic_settings.CliPositionalArg[str] = pydantic.Field(
        description="entry text (free-form); MUST end with the attribution trailer '-- <who> · <session-id>' on its own final line"
    )
    source: str | None = pydantic.Field(
        None,
        validation_alias=pydantic.AliasChoices("s", "source"),
        description="optional source recorded in the entry metadata",
        json_schema_extra={"mcp_exclude": True},
    )

    def run(self, notes):
        return f"logged {notes.create_log(self.body)}"

    def cli_cmd(self):
        print(
            self.run(Notes(resolve_root(), source=resolve_source(self.source)))
        )


TOOLS = [
    SearchNotes,
    ReadNote,
    WriteNote,
    EditNote,
    MoveNote,
    DeleteNote,
    LogNote,
]


def clean_schema(schema):
    """Reduce a pydantic model_json_schema to the MCP inputSchema shape:
    strip 'title', collapse nullable anyOf, keep properties/required. Fields
    marked json_schema_extra={'mcp_exclude': True} are CLI-only and dropped from
    the MCP tool surface entirely."""
    properties = {}
    required = list(schema.get("required", []))
    for name, spec in schema.get("properties", {}).items():
        spec = {k: v for k, v in spec.items() if k != "title"}
        if spec.pop("mcp_exclude", False):
            if name in required:
                required.remove(name)
            continue
        if "anyOf" in spec:
            types = [
                option
                for option in spec.pop("anyOf")
                if option.get("type") != "null"
            ]
            if len(types) == 1:
                spec["type"] = types[0]["type"]
        properties[name] = spec
    cleaned = {"type": "object", "properties": properties}
    if required:
        cleaned["required"] = required
    return cleaned


class NotesMcp(McpStdioServer):
    TOOL_ERROR = UserError
    INSTRUCTIONS = (
        "This is the user's personal notes — the canonical place where they "
        "keep and organize their own notes, ideas, todos, and log entries "
        "as a nested tree of Markdown (.md) files. Whenever the user refers to "
        "'my notes', asks to look something up, record or jot something down, "
        "or check what they've written before, use these tools instead of "
        "guessing or answering from memory. Search, read, write, edit, move, "
        "and delete notes by relative path (e.g. 'proj/ideas.md'). Use LogNote "
        "to quickly capture an immutable, timestamped log entry (its "
        "metadata is auto-generated and it cannot be edited or deleted)."
    )

    def __init__(self, notes):
        self.notes = notes
        super().__init__(name="notes", version="1")

    def register(self):
        for cls in TOOLS:
            self.register_tool(
                cls.__name__,
                (cls.__doc__ or "").strip(),
                clean_schema(cls.model_json_schema()),
                self._make_handler(cls),
            )

    def _make_handler(self, cls):
        def handler(arguments):
            try:
                tool = cls(**arguments)
            except pydantic.ValidationError as error:
                raise UserError(str(error))
            return tool.run(self.notes)

        return handler


class Mcp(pydantic.BaseModel):
    """Run the MCP stdio server (JSON-RPC over stdin/stdout)."""

    source: str | None = pydantic.Field(
        None,
        validation_alias=pydantic.AliasChoices("s", "source"),
        description="constant source recorded on every log entry created via this server",
    )

    def cli_cmd(self):
        NotesMcp(
            Notes(resolve_root(), source=resolve_source(self.source))
        ).serve()


class App(pydantic_settings.BaseSettings):
    model_config = pydantic_settings.SettingsConfigDict(
        cli_prog_name="notes",
        cli_implicit_flags=True,
    )

    mcp: pydantic_settings.CliSubCommand[Mcp]
    search: pydantic_settings.CliSubCommand[SearchNotes]
    read: pydantic_settings.CliSubCommand[ReadNote]
    write: pydantic_settings.CliSubCommand[WriteNote]
    edit: pydantic_settings.CliSubCommand[EditNote]
    move: pydantic_settings.CliSubCommand[MoveNote]
    delete: pydantic_settings.CliSubCommand[DeleteNote]
    log: pydantic_settings.CliSubCommand[LogNote]

    def cli_cmd(self):
        pydantic_settings.CliApp.run_subcommand(self)


def main():
    pydantic_settings.CliApp.run(App)


if __name__ == "__main__":
    try:
        main()
    except UserError as error:
        print(f"error: {error}", file=sys.stderr)
        sys.exit(1)
