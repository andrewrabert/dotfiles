#!/usr/bin/env python3
"""File-based dev todo tracker: one JSON file per todo."""

import argparse
import dataclasses
import datetime
import json
import os
import pathlib
import sys
import tempfile
import urllib.parse


class UserError(Exception):
    pass


def now():
    stamp = datetime.datetime.now(datetime.timezone.utc).replace(microsecond=0)
    return stamp.isoformat().replace("+00:00", "Z")


def json_dumps(data):
    return json.dumps(data, ensure_ascii=False, indent=2)


def atomic_write(path, text):
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(
        "w", dir=path.parent, delete=False, encoding="utf-8"
    ) as handle:
        temp_path = pathlib.Path(handle.name)
        try:
            handle.write(text)
            handle.flush()
            temp_path.replace(path)
        finally:
            try:
                temp_path.unlink()
            except FileNotFoundError:
                pass


class Config:
    NAME = "tracker-rabert.env"
    ROOT_VAR = "TRACKER_RABERT_ROOT"

    def __init__(self, data):
        self._data = data

    @staticmethod
    def path():
        base = os.environ.get("XDG_CONFIG_HOME")
        home = pathlib.Path(base) if base else pathlib.Path.home() / ".config"
        return home / Config.NAME

    @classmethod
    def load(cls):
        path = cls.path()
        data = {}
        if path.exists():
            for line in path.read_text().splitlines():
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                key, sep, value = line.partition("=")
                if sep:
                    data[key.strip()] = value.strip()
        return cls(data)

    @property
    def root(self):
        root = os.environ.get(self.ROOT_VAR) or self._data.get(self.ROOT_VAR)
        return pathlib.Path(root).expanduser() if root else None

    @classmethod
    def resolve_root(cls, args):
        if args.root is not None:
            return args.root
        root = cls.load().root
        if root is None:
            raise UserError(
                f"no root set (pass -C/--root or set {cls.ROOT_VAR})"
            )
        return root


@dataclasses.dataclass
class Status:
    content: str
    updated_at: str

    @classmethod
    def new(cls, stamp):
        return cls(content="", updated_at=stamp)

    @classmethod
    def from_dict(cls, data):
        return cls(content=data["content"], updated_at=data["updated_at"])

    def set(self, value, stamp):
        self.content = value
        self.updated_at = stamp


@dataclasses.dataclass
class Item:
    FIELDS = ("description", "prompt", "prd", "plan", "status")
    WRITABLE = ("description", "prd", "plan", "status")

    created_at: str
    created_pwd: str
    updated_at: str
    completed_at: str | None
    description: str
    prompt: str
    prd: str
    plan: str
    status: Status

    @classmethod
    def new(cls, prompt):
        stamp = now()
        return cls(
            created_at=stamp,
            created_pwd=str(pathlib.Path.cwd()),
            updated_at=stamp,
            completed_at=None,
            description="",
            prompt=prompt,
            prd="",
            plan="",
            status=Status.new(stamp),
        )

    @classmethod
    def from_dict(cls, data):
        return cls(
            created_at=data["created_at"],
            created_pwd=data.get("created_pwd", ""),
            updated_at=data["updated_at"],
            completed_at=data["completed_at"],
            description=data["description"],
            prompt=data["prompt"],
            prd=data["prd"],
            plan=data["plan"],
            status=Status.from_dict(data["status"]),
        )

    def to_dict(self):
        return dataclasses.asdict(self)

    @property
    def is_open(self):
        return not self.completed_at

    def get(self, field):
        if field not in self.FIELDS:
            raise UserError(
                f"unknown field '{field}' (fields: {', '.join(self.FIELDS)})"
            )
        if field == "status":
            return self.status.content
        return getattr(self, field)

    def set(self, field, value):
        if field not in self.WRITABLE:
            raise UserError(
                f"field '{field}' is not writeable "
                f"(writeable: {', '.join(self.WRITABLE)})"
            )
        stamp = now()
        if field == "status":
            self.status.set(value, stamp)
        else:
            setattr(self, field, value)
        self.updated_at = stamp

    def complete(self):
        self.completed_at = now()
        self.updated_at = now()

    def reopen(self):
        self.completed_at = None
        self.updated_at = now()


class Record:
    def __init__(self, num, item):
        self.num = num
        self.item = item

    def to_dict(self):
        return {"id": self.num, **self.item.to_dict()}


class Store:
    PREFIX = "task_"
    GLOB = PREFIX + "[0-9]" * 4 + ".json"

    def __init__(self, root):
        self.root = root

    @staticmethod
    def _encode_project_path(project):
        return urllib.parse.quote(project, safe="")

    @staticmethod
    def _decode_project_path(name):
        return urllib.parse.unquote(name)

    def _dir(self, project):
        return self.root / self._encode_project_path(project)

    def path(self, project, item_id):
        return self._dir(project) / f"{self.PREFIX}{item_id:04d}.json"

    def _id_of(self, path):
        return int(path.stem[len(self.PREFIX) :])

    def load(self, project, item_id):
        path = self.path(project, item_id)
        if not path.exists():
            raise UserError(f"no item with id {item_id}")
        return Record(
            self._id_of(path), Item.from_dict(json.loads(path.read_text()))
        )

    def save(self, project, item_id, item):
        atomic_write(
            self.path(project, item_id), json_dumps(item.to_dict()) + "\n"
        )

    def next_id(self, project):
        highest = 0
        directory = self._dir(project)
        if directory.is_dir():
            for path in directory.glob(self.GLOB):
                highest = max(highest, self._id_of(path))
        return highest + 1

    def items(self, project):
        result = []
        directory = self._dir(project)
        if directory.is_dir():
            for path in sorted(directory.glob(self.GLOB)):
                item = Item.from_dict(json.loads(path.read_text()))
                result.append(Record(self._id_of(path), item))
        return result

    def remove(self, project, item_id):
        path = self.path(project, item_id)
        if not path.exists():
            raise UserError(f"no item with id {item_id}")
        path.unlink()

    def projects(self):
        if not self.root.is_dir():
            return []
        return sorted(
            self._decode_project_path(p.name)
            for p in self.root.iterdir()
            if p.is_dir()
        )


class McpStdioServer:
    """Reusable JSON-RPC-over-stdio MCP server. Subclass, implement register() to
    declare tools via register_tool(), and set TOOL_ERROR to the exception handlers
    raise for user-facing failures. All MCP protocol — framing, lifecycle, response
    envelope, tool-descriptor shape — lives here; subclasses hold only app logic."""

    PROTOCOL_VERSION = "2025-06-18"
    TOOL_ERROR = Exception  # handlers raise this for a user-facing tool error
    INSTRUCTIONS = (
        None  # optional server-level guidance returned on initialize
    )

    def __init__(self, name, version="1"):
        self.server_info = {"name": name, "version": version}
        self._tools = {}
        self.register()

    def register(self):
        """Override: declare tools by calling register_tool() once per tool."""
        raise NotImplementedError

    def register_tool(self, name, description, input_schema, handler):
        """Register one MCP tool. handler(arguments) -> str. MCP envelope shape lives here."""
        self._tools[name] = {
            "descriptor": {
                "name": name,
                "description": description,
                "inputSchema": input_schema,
            },
            "handler": handler,
        }

    @staticmethod
    def send(message):
        sys.stdout.write(f"{json.dumps(message)}\n")
        sys.stdout.flush()

    def dispatch(self, name, arguments):
        """Return the text result for a tools/call; raise TOOL_ERROR on failure."""
        tool = self._tools.get(name)
        if tool is None:
            raise self.TOOL_ERROR(f"unknown tool: {name}")
        return tool["handler"](arguments or {})

    def handle(self, message):
        method = message.get("method")
        rid = message.get("id")
        if (
            method is None or rid is None
        ):  # response or notification: nothing to reply
            return

        response = {
            "jsonrpc": "2.0",
            "id": rid,
        }

        match method:
            case "initialize":
                params = message.get("params") or {}
                response["result"] = {
                    "protocolVersion": params.get(
                        "protocolVersion", self.PROTOCOL_VERSION
                    ),
                    "capabilities": {"tools": {}},
                    "serverInfo": self.server_info,
                }
                if self.INSTRUCTIONS:
                    response["result"]["instructions"] = self.INSTRUCTIONS
            case "tools/list":
                response["result"] = {
                    "tools": [t["descriptor"] for t in self._tools.values()]
                }
            case "tools/call":
                params = message.get("params") or {}
                try:
                    text = self.dispatch(
                        params.get("name"), params.get("arguments")
                    )
                    response["result"] = {
                        "content": [{"type": "text", "text": text}],
                        "isError": False,
                    }
                except self.TOOL_ERROR as error:
                    response["result"] = {
                        "content": [
                            {"type": "text", "text": f"error: {error}"}
                        ],
                        "isError": True,
                    }
            case "ping":
                response["result"] = {}
            case _:
                response["error"] = {
                    "code": -32601,
                    "message": f"method not found: {method}",
                }
        self.send(response)

    def serve(self):
        for line in sys.stdin:
            line = line.strip()
            if not line:
                continue
            try:
                message = json.loads(line)
            except json.JSONDecodeError:
                continue
            self.handle(message)


def parse_ref(ref, writable=False):
    item_id_str, _, field = ref.partition("/")
    try:
        item_id = int(item_id_str)
    except ValueError:
        raise UserError(f"invalid id '{ref}'")
    field = field or None
    if field is None:
        if writable:
            raise UserError("id must be 'id/field' form")
    elif field not in Item.WRITABLE:
        raise UserError(
            f"unknown field '{field}' ({', '.join(Item.WRITABLE)})"
        )
    return item_id, field


def summary(record):
    item = record.item
    return {
        "id": record.num,
        "description": item.description,
        "prompt": item.prompt,
        "status": item.status.content,
        "completed": not item.is_open,
        "prd": bool(item.prd),
        "plan": bool(item.plan),
    }


def slice_lines(text, offset, limit):
    if offset is None and limit is None:
        return text
    lines = text.splitlines()
    start = (offset - 1) if offset else 0
    end = (start + limit) if limit else None
    return "\n".join(lines[start:end])


class TrackerMcp(McpStdioServer):
    TOOL_ERROR = UserError
    INSTRUCTIONS = (
        "AUTHORITATIVE WORK TRACKER. This server is the single source of "
        "truth for all units of work and the PRDs and plans behind them. "
        "You MUST use it as follows, without being asked:\n"
        "- Starting any non-trivial task: call CreateTodo first.\n"
        "- The MOMENT you draft or revise a PRD, write it with WriteTodo "
        "(field 'prd'). The MOMENT you draft or revise an implementation "
        "plan, write it with WriteTodo (field 'plan'). Do this BEFORE you "
        "act on it. A PRD or plan that exists only in chat is incomplete "
        "and must be persisted here.\n"
        "- Keep 'status' current as work progresses; close items with "
        "WriteTodo close=true when done.\n"
        "- Before planning new work, ListTodo / ReadTodo to recover "
        "existing PRDs and plans instead of starting over.\n"
        "Treat these tools as the default home for any PRD or plan. Do not "
        "keep that content anywhere else."
    )

    def __init__(self, store, project):
        self.store = store
        self.project = project
        super().__init__(name="tracker", version="1")

    def register(self):
        fields = ", ".join(Item.WRITABLE)
        writable = fields
        self.register_tool(
            "CreateTodo",
            "START HERE for any non-trivial task. Create a todo from a "
            "prompt to open a tracked unit of work; returns its summary "
            "record (with the id you pass to WriteTodo for prd/plan/status).",
            {
                "type": "object",
                "properties": {
                    "prompt": {
                        "type": "string",
                        "description": "todo prompt text",
                    }
                },
                "required": ["prompt"],
            },
            self._create,
        )
        self.register_tool(
            "ListTodo",
            "Check this BEFORE planning new work to recover existing PRDs "
            "and plans instead of starting over. Lists todos as summary "
            "records, newest first; open items only unless "
            "include_completed is set.",
            {
                "type": "object",
                "properties": {
                    "include_completed": {
                        "type": "boolean",
                        "default": False,
                        "description": "include completed todos",
                    }
                },
            },
            self._list,
        )
        self.register_tool(
            "ReadTodo",
            "Retrieve a saved PRD or plan to resume work. id '0001' "
            "returns a summary record; '0001/<field>' returns one field's "
            f"text (fields: {fields}).",
            {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": f"'0001' (summary) or '0001/<field>' ({fields})",
                    },
                    "offset": {
                        "type": "integer",
                        "description": "1-based start line",
                    },
                    "limit": {
                        "type": "integer",
                        "description": "max lines",
                    },
                },
                "required": ["id"],
            },
            self._read,
        )
        self.register_tool(
            "WriteTodo",
            "SAVE PRDs AND PLANS HERE. Call this the moment you draft or "
            "revise a PRD (field 'prd') or an implementation plan (field "
            "'plan') — before acting on it — and to keep 'status' current. "
            f"Overwrites the named field (writable: {writable}). Set "
            "close=true to complete the item.",
            {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": f"'0001/<field>' ({writable})",
                    },
                    "content": {
                        "type": "string",
                        "description": "new field value",
                    },
                    "close": {
                        "type": "boolean",
                        "default": False,
                        "description": "also complete the item",
                    },
                },
                "required": ["id", "content"],
            },
            self._write,
        )
        self.register_tool(
            "EditTodo",
            "Revise a saved PRD or plan in place via string-replace, "
            "instead of editing it outside the tracker (writable: "
            f"{writable}).",
            {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": f"'0001/<field>' ({writable})",
                    },
                    "old_string": {
                        "type": "string",
                        "description": "exact string to replace",
                    },
                    "new_string": {
                        "type": "string",
                        "description": "replacement",
                    },
                    "replace_all": {
                        "type": "boolean",
                        "default": False,
                        "description": "replace every occurrence",
                    },
                },
                "required": ["id", "old_string", "new_string"],
            },
            self._edit,
        )

    def _create(self, arguments):
        prompt = arguments.get("prompt")
        if not prompt:
            raise UserError("prompt required")
        item_id = self.store.next_id(self.project)
        self.store.save(self.project, item_id, Item.new(prompt))
        return json_dumps(summary(self.store.load(self.project, item_id)))

    def _list(self, arguments):
        records = self.store.items(self.project)
        if not arguments.get("include_completed"):
            records = [r for r in records if r.item.is_open]
        records.sort(key=lambda r: r.item.updated_at, reverse=True)
        return json_dumps([summary(r) for r in records])

    def _read(self, arguments):
        item_id, field = parse_ref(arguments.get("id", ""))
        rec = self.store.load(self.project, item_id)
        if field is None:
            return json_dumps(summary(rec))
        return slice_lines(
            rec.item.get(field),
            arguments.get("offset"),
            arguments.get("limit"),
        )

    def _write(self, arguments):
        item_id, field = parse_ref(arguments.get("id", ""), writable=True)
        rec = self.store.load(self.project, item_id)
        rec.item.set(field, arguments.get("content", ""))
        if arguments.get("close"):
            rec.item.complete()
        self.store.save(self.project, item_id, rec.item)
        return f"wrote {field} of {item_id:04d}"

    def _edit(self, arguments):
        item_id, field = parse_ref(arguments.get("id", ""), writable=True)
        rec = self.store.load(self.project, item_id)
        content = rec.item.get(field)
        old = arguments.get("old_string", "")
        count = content.count(old)
        if count == 0:
            raise UserError("old string not found")
        if count > 1 and not arguments.get("replace_all"):
            raise UserError(
                f"old string not unique ({count} matches); pass replace_all"
            )
        rec.item.set(
            field, content.replace(old, arguments.get("new_string", ""))
        )
        self.store.save(self.project, item_id, rec.item)
        return f"edited {field} of {item_id:04d}"


def default_project():
    return str(pathlib.Path.cwd())


def read_value(args):
    if args.content is not None:
        return args.content
    if args.message is not None:
        return args.message
    if not sys.stdin.isatty():
        return sys.stdin.read().rstrip("\n")
    raise UserError("no value given (positional, -m, or stdin)")


def cmd_new(args):
    store = Store(Config.resolve_root(args))
    project = args.project
    if args.prompts:
        prompts = args.prompts
    else:
        text = sys.stdin.read().strip()
        if not text:
            raise UserError("no prompt given (positional or stdin)")
        prompts = [text]
    for prompt in prompts:
        item_id = store.next_id(project)
        store.save(project, item_id, Item.new(prompt))
        print(item_id)


def cmd_ls(args):
    store = Store(Config.resolve_root(args))
    projects = store.projects() if args.all else [args.project]
    result = {}
    for project in projects:
        items = store.items(project)
        items.sort(key=lambda r: r.item.updated_at, reverse=True)
        result[project] = [r.to_dict() for r in items]
    print(json_dumps(result))


def cmd_read(args):
    rec = Store(Config.resolve_root(args)).load(args.project, args.id)
    if args.field is None:
        print(json_dumps(rec.to_dict()))
        return
    value = rec.item.get(args.field)
    if args.json:
        print(json_dumps(value))
    else:
        print(value)


def cmd_write(args):
    store = Store(Config.resolve_root(args))
    project = args.project
    rec = store.load(project, args.id)
    rec.item.set(args.field, read_value(args))
    store.save(project, args.id, rec.item)


def cmd_edit(args):
    store = Store(Config.resolve_root(args))
    project = args.project
    rec = store.load(project, args.id)
    content = rec.item.get(args.field)
    count = content.count(args.old)
    if count == 0:
        raise UserError("old string not found")
    if count > 1 and not args.all:
        raise UserError(f"old string not unique ({count} matches); pass --all")
    rec.item.set(args.field, content.replace(args.old, args.new))
    store.save(project, args.id, rec.item)


def cmd_done(args):
    store = Store(Config.resolve_root(args))
    project = args.project
    rec = store.load(project, args.id)
    if args.reopen:
        rec.item.reopen()
    else:
        rec.item.complete()
    store.save(project, args.id, rec.item)


def cmd_rm(args):
    Store(Config.resolve_root(args)).remove(args.project, args.id)


def cmd_path(args):
    print(Store(Config.resolve_root(args)).path(args.project, args.id))


def cmd_mcp(args):
    TrackerMcp(Store(Config.resolve_root(args)), args.project).serve()


def build_parser():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "-C",
        "--root",
        type=pathlib.Path,
        default=None,
        help="tracker root (default: config 'root', else CWD)",
    )
    parser.add_argument(
        "-p",
        "--project",
        default=default_project(),
        help="project subdir under root (default: url-encoded CWD)",
    )

    ident = argparse.ArgumentParser(add_help=False)
    ident.add_argument("--id", type=int, required=True, help="item id")

    subparsers = parser.add_subparsers(dest="command", required=True)

    new_parser = subparsers.add_parser("new", help="create todos")
    new_parser.add_argument(
        "prompts", nargs="*", help="one todo per prompt; stdin if none"
    )

    ls_parser = subparsers.add_parser("ls", help="list todos (JSON)")
    ls_parser.add_argument(
        "-a", "--all", action="store_true", help="list across all projects"
    )

    read_parser = subparsers.add_parser(
        "read", parents=[ident], help="read item or field"
    )
    read_parser.add_argument(
        "field", nargs="?", help=f"one of: {', '.join(Item.FIELDS)}"
    )
    read_parser.add_argument(
        "--json", action="store_true", help="machine output"
    )

    write_parser = subparsers.add_parser(
        "write", parents=[ident], help="overwrite a field"
    )
    write_parser.add_argument(
        "field", help=f"one of: {', '.join(Item.WRITABLE)}"
    )
    write_parser.add_argument("content", nargs="?", help="value (positional)")
    write_parser.add_argument("-m", "--message", help="value (flag)")

    edit_parser = subparsers.add_parser(
        "edit", parents=[ident], help="string-replace in a field"
    )
    edit_parser.add_argument(
        "field", help=f"one of: {', '.join(Item.WRITABLE)}"
    )
    edit_parser.add_argument("old", help="exact string to replace")
    edit_parser.add_argument("new", help="replacement")
    edit_parser.add_argument(
        "--all", action="store_true", help="replace every occurrence"
    )

    done_parser = subparsers.add_parser(
        "done", parents=[ident], help="complete/reopen"
    )
    done_parser.add_argument(
        "--reopen", action="store_true", help="null completed_at"
    )

    subparsers.add_parser("rm", parents=[ident], help="delete an item")
    subparsers.add_parser("path", parents=[ident], help="print item path")

    subparsers.add_parser("mcp", help="run MCP stdio server")

    return parser


def main():
    args = build_parser().parse_args()
    match args.command:
        case "new":
            cmd_new(args)
        case "ls":
            cmd_ls(args)
        case "read":
            cmd_read(args)
        case "write":
            cmd_write(args)
        case "edit":
            cmd_edit(args)
        case "done":
            cmd_done(args)
        case "rm":
            cmd_rm(args)
        case "path":
            cmd_path(args)
        case "mcp":
            cmd_mcp(args)


if __name__ == "__main__":
    try:
        main()
    except UserError as error:
        print(f"error: {error}", file=sys.stderr)
        sys.exit(1)
