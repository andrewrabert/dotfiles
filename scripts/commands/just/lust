#!/usr/bin/env python3
"""Run just against a personal per-repo justfile stored outside the repo."""

import asyncio
import os
import pathlib
import sys
import urllib.parse

XDG_CONFIG_HOME = pathlib.Path(
    os.environ.get("XDG_CONFIG_HOME") or pathlib.Path.home() / ".config"
)
LUST_DIR = XDG_CONFIG_HOME / "just" / "lust"
LUST_MODULE = LUST_DIR / "lust.just"
AGENTS_MODULE = LUST_DIR / "AGENTS.md"

DEFAULT_JUSTFILE = f"import '{LUST_MODULE}'\n"

LUST_JUST = """\
# Print the path to this justfile
[group('lust')]
file:
    @echo "{{ justfile() }}"

# Print the directory holding this justfile
[group('lust')]
dir:
    @echo "{{ justfile_directory() }}"

# Print agent guidance for using lust
[private]
agents:
    @LUST_AGENTS=1 lust
"""

# Agent guidance, written to AGENTS.md next to the global lust.just and printed
# by the `agents` recipe. Self-contained so a global CLAUDE.md/AGENTS.md can
# simply `@`-include it.
AGENTS_MD = """\
# `lust` — personal per-repo justfile

`lust` runs `just` against a personal justfile stored *outside* the current repo,
keyed by the repo's git remote URL. Use it for personal recipes that should not
be committed to the project.

- Per-repo dir: `~/.config/just/lust/<url-encoded-git-remote>/`
- Justfile lives at `<lust dir>/justfile`; lust auto-creates it and a
  `.justfile.lust` symlink in the repo root on first run.
- `lust dir` — print the per-repo lust directory.
- `lust file` — print the path to the per-repo justfile.
- `lust` (no args) — list recipes.
"""


class UserError(Exception):
    pass


class git:
    @staticmethod
    async def run(*args):
        proc = await asyncio.create_subprocess_exec(
            "git",
            *args,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE,
        )
        stdout, _ = await proc.communicate()
        if proc.returncode != 0:
            raise UserError("not inside a git repository")
        return stdout.decode().strip()

    @staticmethod
    async def toplevel():
        return pathlib.Path(await git.run("rev-parse", "--show-toplevel"))

    @staticmethod
    async def remote_url():
        for remote in ("upstream", "origin"):
            proc = await asyncio.create_subprocess_exec(
                "git",
                "remote",
                "get-url",
                remote,
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.DEVNULL,
            )
            stdout, _ = await proc.communicate()
            if proc.returncode == 0:
                return stdout.decode().strip()
        raise UserError("no git remote found")


async def justfile_path():
    raw_url = await git.remote_url()
    encoded = urllib.parse.quote(raw_url, safe="")
    return LUST_DIR / encoded / "justfile"


def ensure_agents():
    LUST_DIR.mkdir(parents=True, exist_ok=True)
    if not AGENTS_MODULE.exists() or AGENTS_MODULE.read_text() != AGENTS_MD:
        AGENTS_MODULE.write_text(AGENTS_MD)


async def agents_main():
    ensure_agents()
    sys.stdout.write(AGENTS_MD)


def link_justfile(justfile, git_root):
    link = git_root / ".justfile.lust"
    if link.is_symlink() or link.exists():
        if link.resolve() != justfile.resolve():
            raise UserError(f"{link} exists but does not point to {justfile}")
        return
    if justfile.exists():
        link.symlink_to(justfile)


def just_env(justfile, git_root):
    env = os.environ.copy()
    env["JUST_JUSTFILE"] = str(justfile)
    env["JUST_WORKING_DIRECTORY"] = str(git_root)
    env["LUST_REPO_DIR"] = str(justfile.parent)
    return env


async def main():
    justfile = await justfile_path()
    git_root = await git.toplevel()

    LUST_MODULE.parent.mkdir(parents=True, exist_ok=True)
    if not LUST_MODULE.exists() or LUST_MODULE.read_text() != LUST_JUST:
        LUST_MODULE.write_text(LUST_JUST)
    ensure_agents()

    if not justfile.exists():
        justfile.parent.mkdir(parents=True, exist_ok=True)
        justfile.write_text(DEFAULT_JUSTFILE)
        print(f"Created {justfile}", file=sys.stderr)

    link_justfile(justfile, git_root)
    proc = await asyncio.create_subprocess_exec(
        "just",
        "--justfile",
        str(justfile),
        "--working-directory",
        str(git_root),
        "--default-list",
        *sys.argv[1:],
        env=just_env(justfile, git_root),
    )
    await proc.wait()
    sys.exit(proc.returncode)


if __name__ == "__main__":
    entry = agents_main if os.environ.get("LUST_AGENTS") else main
    try:
        asyncio.run(entry())
    except UserError as e:
        print(f"error: {e}", file=sys.stderr)
        sys.exit(1)
