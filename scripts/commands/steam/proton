    sharpness: typing.Annotated[
        typing.Optional[int],
        typer.Option(
            "--sharpness",
            rich_help_panel=PANEL_GAMESCOPE,
            metavar="0-20",
            help="FSR/NIS sharpness (0 max .. 20 min)",
        ),
    ] = None,
    gs_refresh: typing.Annotated[
        typing.Optional[int],
        typer.Option(
            "--gs-refresh",
            rich_help_panel=PANEL_GAMESCOPE,
            metavar="FPS",
            help="gamescope nested refresh rate",
        ),
    ] = None,
    mouse_sensitivity: typing.Annotated[
        typing.Optional[float],
        typer.Option(
            "--mouse-sensitivity",
            rich_help_panel=PANEL_GAMESCOPE,
            help="multiply mouse movement",
        ),
    ] = None,
    backend: typing.Annotated[
        typing.Optional[str],
        typer.Option(
            "--backend",
            rich_help_panel=PANEL_GAMESCOPE,
            metavar="BACKEND",
            help="auto|drm|sdl|openvr|headless|wayland",
        ),
    ] = None,
    prefer_output: typing.Annotated[
        typing.Optional[str],
        typer.Option(
            "--prefer-output",
            rich_help_panel=PANEL_GAMESCOPE,
            metavar="CONNECTORS",
            help="preferred output connectors (e.g. DP-1,HDMI-A-1)",
        ),
    ] = None,
    orientation: typing.Annotated[
        typing.Optional[str],
        typer.Option(
            "--orientation",
            rich_help_panel=PANEL_GAMESCOPE,
            metavar="DIR",
            help="rotate display: normal|left|right|upsidedown",
        ),
    ] = None,
    framerate_limit: typing.Annotated[
        typing.Optional[int],
        typer.Option(
            "--framerate-limit",
            rich_help_panel=PANEL_GAMESCOPE,
            metavar="FPS",
            help="gamescope framerate limit",
        ),
    ] = None,
    # --- Gamescope (env-var passthroughs) ---
    gamescope_wsi: typing.Annotated[
        typing.Optional[bool],
        typer.Option(
            "--gamescope-wsi/--no-gamescope-wsi",
            envvar="ENABLE_GAMESCOPE_WSI",
            rich_help_panel=PANEL_GAMESCOPE,
            help="gamescope WSI layer (disable to fix some games)",
        ),
    ] = None,
    gamescope_tearing: typing.Annotated[
        typing.Optional[bool],
        typer.Option(
            "--gamescope-tearing/--no-gamescope-tearing",
            envvar="GAMESCOPE_ALLOW_TEARING",
            rich_help_panel=PANEL_GAMESCOPE,
            help="allow tearing",
        ),
    ] = None,
    gamescope_limiter_file: typing.Annotated[
        typing.Optional[str],
        typer.Option(
            "--gamescope-limiter-file",
            envvar="GAMESCOPE_LIMITER_FILE",
            rich_help_panel=PANEL_GAMESCOPE,
            metavar="FILE",
            help="path to a live fps-limit file",
        ),
    ] = None,
    dxvk_hdr: typing.Annotated[
        typing.Optional[bool],
        typer.Option(
            "--dxvk-hdr/--no-dxvk-hdr",
            envvar="DXVK_HDR",
            rich_help_panel=PANEL_GAMESCOPE,
            help="DXVK HDR signalling (pairs with --gamescope-hdr)",
        ),
    ] = None,
):
    if winearch not in ("win32", "win64"):
        raise typer.BadParameter("winearch must be win32 or win64")

    if cd:
        raise typer.BadParameter("cd zsh integration failure")

    args = args or []
    prefix = resolve_prefix(prefix)

    versions = installed_versions()
    if show_versions:
        for version in sorted(versions):
            print(version)
        raise typer.Exit()

    proton_bin = versions[use]

    if not args:
        if prefix.is_dir():
            print(prefix)
            raise typer.Exit()
        else:
            raise typer.BadParameter("no such prefix")

    if not prefix.is_dir():
        prefix.mkdir(exist_ok=True, parents=True)
        try:
            case_insensitivty(prefix)
        except CasefoldUnsupported:
            print("Casefold not supported. Ignoring")

    cmd = args
    if args[0][:3].lower() == "c:\\":
        path = prefix / "pfx" / "drive_c"
        parts = args[0][3:].split("\\")
        for part in parts[:-1]:
            path = path / part
        os.chdir(path)
        cmd = [path / parts[-1], *args[1:]]

    if desktop:
        w, h = desktop.split("x")
        cmd = ["explorer", f"/desktop=proton,{w}x{h}", *cmd]

    os.environ.update(
        {
            "STEAMAPPS_COMMON": str(STEAM_ROOT / "steamapps" / "common"),
            "STEAM_COMPAT_CLIENT_INSTALL_PATH": str(STEAM_ROOT),
            "STEAM_COMPAT_DATA_PATH": str(prefix),
            "WINEARCH": winearch,
            "WINEPREFIX": str(prefix / "pfx"),
        }
    )
    wayland = bool(os.environ.get("WAYLAND_DISPLAY")) and not no_wayland
    os.environ["PROTON_ENABLE_WAYLAND"] = "1" if wayland else "0"

    env_flags = {
        "WINE_FULLSCREEN_FSR": fsr,
        "WINE_FULLSCREEN_FSR_STRENGTH": fsr_strength,
        "WINE_FULLSCREEN_FSR_CUSTOM_MODE": fsr_mode,
        "PROTON_FSR3_UPGRADE": fsr3,
        "PROTON_FSR4_UPGRADE": fsr4,
        "PROTON_FSR4_RDNA3_UPGRADE": fsr4_rdna3,
        "PROTON_FSR4_INDICATOR": fsr4_hud,
        "PROTON_DLSS_UPGRADE": dlss,
        "PROTON_DLSS_INDICATOR": dlss_hud,
        "PROTON_XESS_UPGRADE": xess,
        "PROTON_USE_OPTISCALER": optiscaler,
        "PROTON_USE_WINED3D": wined3d,
        "PROTON_USE_WINED3D11": wined3d11,
        "PROTON_USE_D7VK": d7vk,
        "PROTON_DXVK_D3D8": dxvk_d3d8,
        "PROTON_NO_D3D11": no_d3d11,
        "PROTON_NO_D3D10": no_d3d10,
        "PROTON_OLD_GL_STRING": old_gl_string,
        "WINE_DO_NOT_CREATE_DXGI_DEVICE_MANAGER": no_dxgi_device_manager,
        "PROTON_HIDE_NVIDIA_GPU": hide_nvidia,
        "PROTON_HIDE_INTEL_GPU": hide_intel,
        "PROTON_HIDE_APU": hide_apu,
        "PROTON_HIDE_VANGOGH_GPU": hide_vangogh,
        "PROTON_DISABLE_NVAPI": no_nvapi,
        "PROTON_FORCE_NVAPI": force_nvapi,
        "PROTON_NATIVE_AGS": native_ags,
        "PROTON_NO_ESYNC": no_esync,
        "PROTON_NO_FSYNC": no_fsync,
        "PROTON_NO_NTSYNC": no_ntsync,
        "PROTON_HEAP_DELAY_FREE": heap_delay_free,
        "PROTON_HEAP_ZERO_MEMORY": heap_zero,
        "PROTON_USE_WRITECOPY": writecopy,
        "PROTON_FORCE_LARGE_ADDRESS_AWARE": force_lgadd,
        "PROTON_LIMIT_ADDRESS_SPACE": limit_address_space,
        "PROTON_USE_SDL": sdl,
        "PROTON_PREFER_SDL": prefer_sdl,
        "PROTON_DISABLE_HIDRAW": no_hidraw,
        "PROTON_EMULATE_STEAMINPUT": emulate_steaminput,
        "PROTON_NO_STEAMINPUT": no_steaminput,
        "PROTON_SET_GAME_DRIVE": game_drive,
        "PROTON_SET_STEAM_DRIVE": steam_drive,
        "PROTON_ENABLE_HDR": hdr,
        "PROTON_NO_WM_DECORATION": no_wm_decoration,
        "PROTON_NO_XIM": no_xim,
        "PROTON_USE_ARM64": arm64,
        "PROTON_CPU_TOPOLOGY": cpu_topology,
        "PROTON_LIMIT_RESOLUTIONS": limit_resolutions,
        "PROTON_MEDIACONV_NO_VIDEO": no_mediaconv_video,
        "PROTON_WAYLAND_MONITOR": wayland_monitor,
        "PROTON_LOG_DIR": log_dir,
        "PROTON_CRASH_REPORT_DIR": crash_report_dir,
        "ENABLE_GAMESCOPE_WSI": gamescope_wsi,
        "GAMESCOPE_ALLOW_TEARING": gamescope_tearing,
        "GAMESCOPE_LIMITER_FILE": gamescope_limiter_file,
        "DXVK_HDR": dxvk_hdr,
    }
    for var, value in env_flags.items():
        if value is None:
            continue
        os.environ[var] = (
            "1" if value is True else "0" if value is False else str(value)
        )

    if auto_dpi and (scale := kde_primary_scale()):
        dpi = round(96 * scale)
        subprocess.run(
            [
                proton_bin[0],
                "run",
                "reg",
                "add",
                "HKCU\\Control Panel\\Desktop",
                "/v",
                "LogPixels",
                "/t",
                "REG_DWORD",
                "/d",
                str(dpi),
                "/f",
            ],
            check=True,
        )

    gs_bool = [
        flag
        for flag, on in (
            ("--mangoapp", mangoapp),
            ("--adaptive-sync", adaptive_sync),
            ("--immediate-flips", immediate_flips),
            ("--force-grab-cursor", force_grab_cursor),
            ("-g", grab),
            ("-b", borderless),
            ("--expose-wayland", expose_wayland),
            ("--force-windows-fullscreen", force_windows_fullscreen),
            ("-e", steam_integration),
            ("--hdr-enabled", gamescope_hdr),
            ("--hdr-itm-enabled", hdr_itm),
        )
        if on
    ]
    gs_value = []
    for flag, value in (
        ("-S", scaler),
        ("-F", filter),
        ("--fsr-sharpness", sharpness),
        ("-r", gs_refresh),
        ("-s", mouse_sensitivity),
        ("--backend", backend),
        ("-O", prefer_output),
        ("--force-orientation", orientation),
        ("--framerate-limit", framerate_limit),
    ):
        if value is not None:
            gs_value += [flag, str(value)]

    if gamescope or resolution or fullscreen or gs_bool or gs_value:
        gamescope_cmd = ["gamescope"]
        if resolution:
            w, h = resolution.split("x")
            gamescope_cmd += ["-w", w, "-h", h, "-W", w, "-H", h]
        if fullscreen:
            gamescope_cmd += ["-f"]
        gamescope_cmd += gs_bool + gs_value
        gamescope_cmd += ["--"] + [proton_bin[0]] + proton_bin[2:] + cmd
        os.execvp("gamescope", gamescope_cmd)
    else:
        os.execl(*proton_bin, *cmd)


if __name__ == "__main__":
    typer.run(main)
