#!/usr/bin/env python3
"""Count Rust comment occurrences per top-level src/ subdirectory."""

import argparse
import asyncio
import pathlib
import sys


def count_lines(directory):
    total = 0
    for path in directory.rglob("*.rs"):
        total += path.read_bytes().count(b"\n")
    return total


async def count_comments(directory):
    async def run(pattern):
        proc = await asyncio.create_subprocess_exec(
            "ast-grep",
            "run",
            "--pattern",
            pattern,
            "-l",
            "rust",
            str(directory),
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.DEVNULL,
        )
        stdout, _ = await proc.communicate()
        return stdout.count(b"\n")

    counts = await asyncio.gather(run("// $_"), run("/* $_ */"))
    return sum(counts)


async def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "path", nargs="?", type=pathlib.Path, default=pathlib.Path("src")
    )
    args = parser.parse_args()

    src = args.path
    if not src.is_dir():
        print(f"error: {src} is not a directory", file=sys.stderr)
        sys.exit(1)

    dirs = sorted(
        p for p in src.iterdir() if p.is_dir() and p.name != "target"
    )
    comment_counts = await asyncio.gather(*[count_comments(d) for d in dirs])
    line_counts = [count_lines(d) for d in dirs]

    rows = sorted(
        zip(dirs, comment_counts, line_counts),
        key=lambda x: x[1],
        reverse=True,
    )
    rows = [(d.name, c, l) for d, c, l in rows if c > 0]

    if not rows:
        print("no comments found")
        return

    width = max(len(name) for name, _, _ in rows)
    for name, comments, lines in rows:
        pct = comments / lines * 100 if lines else 0
        print(f"{name:<{width}}  {pct:5.1f}%  ({lines})")


if __name__ == "__main__":
    asyncio.run(main())
