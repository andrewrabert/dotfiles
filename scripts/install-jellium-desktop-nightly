#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = [
#     "httpx2",
#     "pydantic",
#     "pydantic-settings",
#     "rich",
# ]
# ///
"""Download and install the latest Jellium Desktop nightly.

Takes one positional argument selecting the build:

    flatpak - x86_64 Linux flatpak, installed with `flatpak install --user`
    macos   - arm64 macOS app, installed into /Applications

By default the build is installed on the machine running this script. Pass
`--ssh <host>` to install on a remote host instead: the download and extraction
still happen locally (only this machine needs Python/uv), and the extracted
artifact is pushed to the remote where the install commands run over SSH."""

import abc
import asyncio
import os
import pathlib
import plistlib
import re
import shlex
import shutil
import sys
import tempfile
import typing
import zipfile

import httpx2
import pydantic
import pydantic_settings
import rich.progress


class UserError(Exception):
    pass


class ProcessError(Exception):
    def __init__(self, process, message=None):
        self.process = process
        self.message = message

    def __str__(self):
        text = f"exit {self.process.returncode}"
        if self.message:
            text = f"{text} - {self.message}"
        return text


async def run_bytes(*args):
    proc = await asyncio.create_subprocess_exec(
        *(str(arg) for arg in args),
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.PIPE,
    )
    stdout, stderr = await proc.communicate()
    if proc.returncode:
        raise ProcessError(proc, stderr.decode().strip())
    return stdout


async def run(*args):
    return (await run_bytes(*args)).decode()


class Host(abc.ABC):
    """The set of target-host operations the installers need. `LocalHost`
    performs them on this machine; `SshHost` performs them on a remote host
    over SSH so the remote never needs Python."""

    label: str

    @abc.abstractmethod
    async def run(self, *args):
        """Run a command on the host, returning its stdout."""

    @abc.abstractmethod
    async def read_bytes(self, path):
        """Return the raw contents of a file on the host."""

    @abc.abstractmethod
    async def push(self, local, dest_dir):
        """Copy a local file into `dest_dir` on the host, returning its path."""

    @abc.abstractmethod
    async def mkdtemp(self):
        """Create and return a fresh temporary directory on the host."""

    @abc.abstractmethod
    async def exists(self, path):
        pass

    @abc.abstractmethod
    async def is_dir(self, path):
        pass

    @abc.abstractmethod
    async def mkdir(self, path):
        pass

    @abc.abstractmethod
    async def rmtree(self, path):
        pass


class LocalHost(Host):
    label = "local"

    async def run(self, *args):
        return await run(*args)

    async def read_bytes(self, path):
        return pathlib.Path(path).read_bytes()

    async def push(self, local, dest_dir):
        return local

    async def mkdtemp(self):
        return pathlib.Path(tempfile.mkdtemp())

    async def exists(self, path):
        return pathlib.Path(path).exists()

    async def is_dir(self, path):
        return pathlib.Path(path).is_dir()

    async def mkdir(self, path):
        pathlib.Path(path).mkdir(parents=True, exist_ok=True)

    async def rmtree(self, path):
        shutil.rmtree(path)


class SshHost(Host):
    def __init__(self, host):
        self.label = host
        self._host = host

    async def _run_bytes(self, *args):
        # A tty is needed only for the sudo password prompt; it would mangle
        # binary output, so cat/other reads deliberately go without one.
        tty = bool(args) and str(args[0]) == "sudo"
        remote = " ".join(shlex.quote(str(arg)) for arg in args)
        cmd = ["ssh"]
        if tty:
            cmd.append("-tt")
        cmd += [self._host, remote]
        return await run_bytes(*cmd)

    async def run(self, *args):
        return (await self._run_bytes(*args)).decode()

    async def read_bytes(self, path):
        return await self._run_bytes("cat", path)

    async def push(self, local, dest_dir):
        dest = pathlib.PurePosixPath(dest_dir) / pathlib.PurePosixPath(local).name
        await run("scp", "-q", local, f"{self._host}:{dest}")
        return dest

    async def mkdtemp(self):
        return pathlib.PurePosixPath((await self.run("mktemp", "-d")).strip())

    async def _test(self, flag, path):
        try:
            await self.run("test", flag, path)
            return True
        except ProcessError:
            return False

    async def exists(self, path):
        return await self._test("-e", path)

    async def is_dir(self, path):
        return await self._test("-d", path)

    async def mkdir(self, path):
        await self.run("mkdir", "-p", path)

    async def rmtree(self, path):
        await self.run("rm", "-rf", path)


def sole_file(directory):
    """Return the single file under `directory`, erroring on any other count."""
    files = sorted(p for p in directory.rglob("*") if p.is_file())
    if len(files) != 1:
        raise UserError(
            f"expected exactly one file in download, found {len(files)}"
        )
    return files[0]


class Build(pydantic.BaseModel):
    workflow: str
    archive_name: str
    key: str


class Nightly:
    """A downloadable nightly artifact: knows its URL, streams it with a
    progress bar, and caches the last-installed ETag in a host-appropriate
    cache dir so repeat runs short-circuit. The cache lives on this machine
    and is keyed by target host, so local and remote installs stay separate."""

    BASE = "https://nightly.link/andrewrabert/jellium-desktop/workflows"

    def __init__(self, build, label="local"):
        self.url = pydantic.HttpUrl(
            f"{self.BASE}/{build.workflow}/main/{build.archive_name}"
        )
        self.archive_name = build.archive_name
        safe = re.sub(r"[^A-Za-z0-9._-]", "_", label)
        self._etag_file = (
            self._cache_dir()
            / "jellium-desktop-nightly"
            / f"{build.key}.{safe}.etag"
        )
        self._etag = None

    @staticmethod
    def _cache_dir():
        if sys.platform == "darwin":
            return pathlib.Path.home() / "Library" / "Caches"
        return pathlib.Path(
            os.environ.get("XDG_CACHE_HOME") or pathlib.Path.home() / ".cache"
        )

    def _stored_etag(self):
        try:
            return self._etag_file.read_text().strip()
        except FileNotFoundError:
            return None

    async def fetch(self, dest):
        """Stream the artifact to `dest`. Returns True if a new build was
        downloaded, False when the cached ETag is still current."""
        known = self._stored_etag()
        async with httpx2.AsyncClient() as client:
            async with client.stream(
                "GET", str(self.url), follow_redirects=True
            ) as response:
                response.raise_for_status()
                self._etag = response.headers.get("etag")
                if self._etag and self._etag == known:
                    return False
                await self._download(response, dest)
                return True

    def commit(self):
        """Persist the fetched build's ETag after a successful install."""
        if self._etag:
            self._etag_file.parent.mkdir(parents=True, exist_ok=True)
            self._etag_file.write_text(self._etag)
            print(f"Stored etag {self._etag}")

    @staticmethod
    async def _download(response, dest):
        total = int(response.headers.get("content-length", 0)) or None
        columns = (
            rich.progress.TextColumn("Downloading"),
            rich.progress.BarColumn(),
            rich.progress.DownloadColumn(),
            rich.progress.TransferSpeedColumn(),
            rich.progress.TimeRemainingColumn(),
        )
        with rich.progress.Progress(*columns) as progress:
            task = progress.add_task("download", total=total)
            with dest.open("wb") as handle:
                async for chunk in response.aiter_bytes():
                    handle.write(chunk)
                    progress.update(task, advance=len(chunk))


class Flatpak:
    """The single .flatpak bundle from a linux-flatpak download."""

    def __init__(self, path):
        if path.suffix != ".flatpak":
            raise UserError(f"expected a .flatpak, got {path.name}")
        self.path = path

    async def install(self, host):
        print("Installing...")
        await host.run(
            "flatpak",
            "install",
            "--user",
            "--noninteractive",
            "--or-update",
            self.path,
        )
        print("Installed")


class Dmg:
    """The single .dmg from a macOS download; its contents are constant."""

    APP_NAME = "Jellium Desktop.app"
    applications = pathlib.PurePosixPath("/Applications")

    def __init__(self, path):
        if path.suffix != ".dmg":
            raise UserError(f"expected a .dmg, got {path.name}")
        self.path = path

    @staticmethod
    async def _version(host, app):
        """Return the full version string from an app's Info.plist."""
        info = app / "Contents" / "Info.plist"
        plist = plistlib.loads(await host.read_bytes(info))
        short = plist.get("CFBundleShortVersionString")
        build = plist.get("CFBundleVersion")
        if short and build and short != build:
            return f"{short} ({build})"
        return short or build or "unknown"

    @staticmethod
    async def _is_quarantined(host, app):
        """Return True if any file under the app carries the Gatekeeper
        quarantine attribute. com.apple.provenance is ignored - macOS re-adds it
        on launch and cannot be cleared, so it is not a meaningful signal."""
        output = await host.run("xattr", "-r", app)
        return "com.apple.quarantine" in output

    async def install(self, host):
        mount = self.path.parent / "mnt"
        await host.mkdir(mount)
        try:
            await host.run(
                "hdiutil",
                "attach",
                "-nobrowse",
                "-mountpoint",
                mount,
                self.path,
            )
            app = mount / self.APP_NAME
            if not await host.is_dir(app):
                raise UserError(
                    f"{self.APP_NAME} not found in {self.path.name}"
                )

            version = await self._version(host, app)
            print(f"Version: {version}")

            dest = self.applications / app.name
            installed = (
                await self._version(host, dest)
                if await host.exists(dest)
                else None
            )
            if installed == version:
                print(f"Already installed: {dest}")
            else:
                if installed is not None:
                    print(f"Replacing installed version {installed}")
                print(f"Installing to {dest}...")
                if await host.exists(dest):
                    await host.rmtree(dest)
                await host.run("ditto", app, dest)
                print(f"Installed: {dest}")
        finally:
            await host.run("hdiutil", "detach", mount)

        if await self._is_quarantined(host, dest):
            print("Clearing quarantine (sudo)...")
            await host.run("sudo", "xattr", "-dr", "com.apple.quarantine", dest)


class Platform(pydantic.BaseModel):
    """Base for platform subcommands: shares the download/extract flow and the
    `--ssh` target selection."""

    ssh: str | None = None

    def cli_cmd(self):
        host = SshHost(self.ssh) if self.ssh else LocalHost()
        asyncio.run(run_install(self, host))


class FlatpakCmd(Platform):
    build: typing.ClassVar[Build] = Build(
        workflow="build-linux-flatpak",
        archive_name="linux-flatpak-x86_64.zip",
        key="flatpak",
    )
    payload: typing.ClassVar[type] = Flatpak


class MacosCmd(Platform):
    build: typing.ClassVar[Build] = Build(
        workflow="build-macos",
        archive_name="macos-arm64.zip",
        key="macos",
    )
    payload: typing.ClassVar[type] = Dmg


async def run_install(cmd, host):
    nightly = Nightly(cmd.build, host.label)
    with tempfile.TemporaryDirectory() as tmp:
        work = pathlib.Path(tmp)
        archive = work / nightly.archive_name

        if not await nightly.fetch(archive):
            print("Already up to date")
            return

        print("Extracting...")
        extracted = work / "extracted"
        with zipfile.ZipFile(archive) as zf:
            zf.extractall(extracted)

        staging = await host.mkdtemp()
        try:
            path = await host.push(sole_file(extracted), staging)
            await cmd.payload(path).install(host)
            nightly.commit()
        finally:
            await host.rmtree(staging)


class App(pydantic_settings.BaseSettings):
    """Download and install the latest Jellium Desktop nightly."""

    model_config = pydantic_settings.SettingsConfigDict(cli_parse_args=True)
    ssh: str | None = None
    flatpak: pydantic_settings.CliSubCommand[FlatpakCmd]
    macos: pydantic_settings.CliSubCommand[MacosCmd]

    def cli_cmd(self):
        sub = pydantic_settings.get_subcommand(self)
        if self.ssh:
            sub.ssh = self.ssh
        sub.cli_cmd()


if __name__ == "__main__":
    pydantic_settings.CliApp.run(App)
