#!/usr/bin/env python3
import argparse
import contextlib
import datetime
import json
import pathlib
import shutil
import subprocess
import tempfile


@contextlib.contextmanager
def TempPath(**kwargs):
    """Wrapper around tempfile.NamedTemporaryFile which returns a path object

    Unlike tempfile.NamedTemporaryFile, the FileNotFoundError exception is not
    raised if the file is deleted before the context closes.

    :rtype: pathlib.Path
    """
    with tempfile.NamedTemporaryFile(**kwargs, delete=False) as tmp:
        temp_path = pathlib.Path(tmp.name)
        try:
            yield temp_path
        finally:
            try:
                temp_path.unlink()
            except FileNotFoundError:
                pass


def gifski(path, target, framerate="30", loops=1):
    frames = sorted(path.iterdir())
    # gifski defaults to capping anims at ~800x600; pass explicit --width
    # so frame dimensions are preserved.
    width = vips_width(frames[0])
    with TempPath(
        dir=target.parent,
        prefix=".img-to-interpolated-video",
        suffix=target.suffix,
    ) as tmptarget:
        subprocess.run(
            [
                "gifski",
                "--quiet",
                "--extra",
                "--width",
                str(width),
                "--fps",
                framerate,
                "--output",
                tmptarget,
                "--",
                *frames,
            ],
            stdout=subprocess.DEVNULL,
            check=True,
        )
        tmptarget.replace(target)


# -an drops audio so players (e.g. Signal) treat output as a looping animation.
CODEC_ARGS = {
    "mp4": [
        "-an",
        "-c:v",
        "libx264",
        "-preset",
        "slow",
        "-crf",
        "16",
        "-movflags",
        "+faststart",
    ],
    "webm": ["-an", "-c:v", "libvpx-vp9", "-crf", "30", "-b:v", "0"],
    "webp": ["-an", "-c:v", "libwebp_anim", "-loop", "0", "-quality", "90"],
}


def ffmpeg_merge(path, target, framerate="30", loops=1, codec_args=None):
    if codec_args is None:
        codec_args = CODEC_ARGS["mp4"]
    with TempPath(
        dir=target.parent,
        prefix=".img-to-interpolated-video",
        suffix=target.suffix,
    ) as tmptarget:
        subprocess.run(
            [
                "ffmpeg",
                "-y",
                "-stream_loop",
                str(loops),
                "-framerate",
                framerate,
                "-pattern_type",
                "glob",
                "-i",
                f"{path}/*.png",
                *codec_args,
                tmptarget,
            ],
            stdout=subprocess.DEVNULL,
            check=True,
        )
        tmptarget.replace(target)


def vips_width(path):
    proc = subprocess.run(
        ["vipsheader", "-f", "width", "--", path],
        stdout=subprocess.PIPE,
        check=True,
    )
    return int(proc.stdout)


def vips_scale_frames(path, target, scale):
    for src in sorted(path.iterdir()):
        subprocess.run(
            ["vips", "resize", src, target / src.name, str(scale)],
            check=True,
        )


def blend_frames(path, target, n):
    # Average each non-overlapping group of n frames into one (motion blur).
    # Done per-group with ImageMagick rather than ffmpeg temporal filters,
    # which miscount frames when the source PNGs carry identical timestamps.
    frames = sorted(path.iterdir())
    for i in range(0, len(frames), n):
        group = frames[i : i + n]
        subprocess.run(
            ["magick", *group, "-evaluate-sequence", "Mean", target / f"{i:08d}.png"],
            check=True,
        )


def ffmpeg_frames_to_png(path, target, remove_duplicates=True, ss=None, to=None):
    args = ["ffmpeg"]
    if ss is not None:
        args.extend(["-ss", ss])
    if to is not None:
        args.extend(["-to", to])
    args.extend(["-i", path])
    if remove_duplicates:
        info = ffprobe(path)
        avg_frame_rate = None
        for stream in info:
            if stream.get("codec_type") != "video":
                continue
            avg_frame_rate = stream.get("avg_frame_rate")
            if avg_frame_rate:
                x, y = avg_frame_rate.split("/")
                if int(y) != 0:
                    avg_frame_rate = int(x) / int(y)
                    break
        args.extend(
            [
                "-vsync",
                "0",
                "-vf",
                f"mpdecimate,setpts=N/{round(avg_frame_rate, 3)}/TB",
            ]
        )

    args.extend(
        [
            "-compression_level",
            "0",
            f"{target}/%08d.png",
        ]
    )
    subprocess.run(
        args, stderr=subprocess.DEVNULL, stdout=subprocess.DEVNULL, check=True
    )


def ffprobe(path):
    proc = subprocess.run(
        [
            "ffprobe",
            "-v",
            "error",
            "-show_streams",
            "-print_format",
            "json",
            "--",
            path,
        ],
        stderr=subprocess.DEVNULL,
        stdout=subprocess.PIPE,
        check=True,
    )
    return json.loads(proc.stdout)["streams"]


def rife(source, target, model=None, num_passes=1):
    args = ["rife", "--num-passes", str(num_passes)]
    if model is not None:
        args.extend(["--model", model])
    args.extend(["--", source, target])
    subprocess.run(args, check=True)


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("-o", "--output", type=pathlib.Path)
    parser.add_argument(
        "-l",
        "--loops",
        type=int,
        metavar="NUM",
        default=3,
        help="(default %(default)s)",
    )
    parser.add_argument(
        "-r",
        "--rife-iterations",
        type=int,
        metavar="NUM",
        default=0,
        help="(default %(default)s)",
    )
    parser.add_argument("--rife-model")
    parser.add_argument(
        "--blend",
        type=int,
        metavar="NUM",
        help="average each NUM consecutive frames into one (motion blur)",
    )
    parser.add_argument(
        "--fps", default="30", metavar="FPS", help="(default %(default)s)"
    )
    parser.add_argument(
        "--scale",
        type=float,
        metavar="FACTOR",
        help="resize output by factor (e.g. 0.5 = half size)",
    )
    parser.add_argument(
        "-m",
        "--mode",
        choices=["bounce", "cycle", "oneshot"],
        default="oneshot",
    )
    parser.add_argument("--ss", metavar="TIME", help="start time (ffmpeg -ss)")
    parser.add_argument("--to", metavar="TIME", help="stop time (ffmpeg -to)")
    parser.add_argument("source", type=pathlib.Path)
    parser.add_argument(
        "-f", "--format", default="mp4", choices=["gif", "mp4", "webm", "webp", "png"]
    )
    args = parser.parse_args()

    output = args.output
    if output is None:
        name = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        if args.format in ("mp4", "webm", "webp", "gif"):
            name += f".{args.format}"
        output = pathlib.Path(name)

    with contextlib.ExitStack() as exitstack:
        if args.source.is_file():
            source = pathlib.Path(
                exitstack.enter_context(tempfile.TemporaryDirectory())
            )
            ffmpeg_frames_to_png(args.source, source, ss=args.ss, to=args.to)
        elif args.source.is_dir():
            source = args.source
        else:
            raise FileNotFoundError

        tmpdir = exitstack.enter_context(
            tempfile.TemporaryDirectory(dir=source.parent)
        )
        tmpdir = pathlib.Path(tmpdir)
        sources = sorted(list(source.iterdir()))

        new = [*sources]
        match args.mode:
            case "cycle":
                new.append(sources[0])

        for i, p in enumerate(new):
            shutil.copy(p, tmpdir / f"{i:032d}.png")

        if args.scale is not None and args.scale != 1.0:
            print("Scaling frames")
            tmpdir2 = exitstack.enter_context(
                tempfile.TemporaryDirectory(dir=source.parent)
            )
            tmpdir2 = pathlib.Path(tmpdir2)
            vips_scale_frames(tmpdir, tmpdir2, args.scale)
            shutil.rmtree(tmpdir)
            shutil.move(tmpdir2, tmpdir)

        if args.rife_iterations:
            print("Running rife")
            tmpdir2 = exitstack.enter_context(
                tempfile.TemporaryDirectory(dir=source.parent)
            )
            tmpdir2 = pathlib.Path(tmpdir2)
            rife(
                tmpdir,
                tmpdir2,
                model=args.rife_model,
                num_passes=args.rife_iterations,
            )
            shutil.rmtree(tmpdir)
            shutil.move(tmpdir2, tmpdir)

        if args.blend is not None and args.blend > 1:
            print("Blending frames")
            tmpdir2 = exitstack.enter_context(
                tempfile.TemporaryDirectory(dir=source.parent)
            )
            tmpdir2 = pathlib.Path(tmpdir2)
            blend_frames(tmpdir, tmpdir2, args.blend)
            shutil.rmtree(tmpdir)
            shutil.move(tmpdir2, tmpdir)

        sources = sorted(list(tmpdir.iterdir()))
        match args.mode:
            case "bounce":
                sources = [*sources, *reversed(sources[1:-1])]
                wz = len(str(len(sources)))

                tmpdir2 = exitstack.enter_context(
                    tempfile.TemporaryDirectory(dir=source.parent)
                )
                tmpdir2 = pathlib.Path(tmpdir2)

                for i, path in enumerate(sources):
                    shutil.copy(path, tmpdir2 / (str(i).zfill(wz) + ".png"))
                shutil.rmtree(tmpdir)
                shutil.move(tmpdir2, tmpdir)
            case "cycle":
                sources[-1].unlink()

        match args.format:
            case "mp4" | "webm" | "webp":
                print("Rendering video")
                # webp loops infinitely via -loop 0; duplicating frames with
                # -stream_loop only bloats the file.
                loops = 0 if args.format == "webp" else args.loops
                ffmpeg_merge(
                    tmpdir,
                    output,
                    framerate=args.fps,
                    loops=loops,
                    codec_args=CODEC_ARGS[args.format],
                )
            case "gif":
                print("Rendering gif")
                gifski(
                    tmpdir,
                    output,
                    framerate=args.fps,
                )
            case "png":
                shutil.copytree(tmpdir, output)
            case _:
                raise RuntimeError
        print(output)


if __name__ == "__main__":
    main()
